// Applies a library item to the swarm and routes user to Modeling
function applyLibraryItem(itemId) {
  const item = LIBRARY.find(x => x.id === itemId);
  if (!item) return;
  const customDrones = item.formationFn();
  buildSwarmFromFormation('lib-' + item.id, customDrones.length, customDrones);
  app.swarm.selected.clear();
  showToast(`Loaded "${item.name}" — ${customDrones.length} drones`);
  navigateTo('modeling');
}


