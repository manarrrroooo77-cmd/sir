      </div>
      <div class="doors-filters" id="doorsFilters"></div>
      <button class="doors-upload-btn" id="doorsUpload">
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l5 6h-3v8H6V7H3z"/></svg>
        Add scene
      </button>
    </div>
    <div class="doors-grid-v6" id="doorsGridV6"></div>
  `;
  const gridV6 = document.getElementById('doorsGridV6');

  // Filters
  const allTags = new Set(['All']);
  DOORS.forEach(d => { d.tags.forEach(t => allTags.add(t)); });
  const filtersEl = document.getElementById('doorsFilters');
  filtersEl.innerHTML = [...allTags].slice(0, 7).map(tag =>
    `<div class="doors-filter-chip ${tag === activeFilter ? 'active' : ''}" data-filter="${tag}">${tag}</div>`
  ).join('');
  filtersEl.querySelectorAll('.doors-filter-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      activeFilter = chip.dataset.filter;
      filtersEl.querySelectorAll('.doors-filter-chip').forEach(x => x.classList.toggle('active', x.dataset.filter === activeFilter));
      renderGalleryV6();
    });
  });

  // Search
  const searchEl = document.getElementById('doorsSearch');
  const searchInput = document.getElementById('doorsSearchInput');
  const searchClear = document.getElementById('doorsSearchClear');
  searchInput.addEventListener('input', (e) => {
    searchQuery = e.target.value.toLowerCase().trim();
    searchEl.classList.toggle('has-value', !!searchQuery);
    renderGalleryV6();
  });
  searchClear.addEventListener('click', () => {
    searchInput.value = ''; searchQuery = '';
    searchEl.classList.remove('has-value');
    renderGalleryV6();
  });

  // Upload — opens a hidden file input; converted to a procedural door card
  document.getElementById('doorsUpload').addEventListener('click', () => {
    const fi = document.createElement('input');
    fi.type = 'file'; fi.accept = 'video/*';
    fi.addEventListener('change', (e) => {
      const f = e.target.files[0]; if (!f) return;
      const url = URL.createObjectURL(f);
      const newDoor = {
        id: 'user-' + Date.now(),
        title: f.name.replace(/\.[^/.]+$/, '').slice(0, 30),
        genre: 'User upload',
        desc: 'Imported by you · AI will generate detections automatically.',
        duration: 30,
        tags: ['user', 'upload'],
        videoUrl: url,
        poster: 'aladdin',
        source: 'local',
        accent: '#4dd0e1',
        accent2: '#b388ff',
        detections: [
          { t: 1,  obj: 'Subject',  conf: 0.85, color: 'cyan', box: { x: 25, y: 20, w: 50, h: 60 }, life: 4.5, droneFormation: 'sphere' },
          { t: 7,  obj: 'Movement', conf: 0.78, color: 'orange', box: { x: 30, y: 40, w: 40, h: 30 }, life: 3.5, droneFormation: 'wave' },
          { t: 14, obj: 'Highlight', conf: 0.82, color: 'pink', box: { x: 30, y: 25, w: 40, h: 50 }, life: 4.0, droneFormation: 'star' },
          { t: 22, obj: 'Finale',  conf: 0.88, color: 'purple', box: { x: 25, y: 20, w: 50, h: 60 }, life: 5.0, droneFormation: 'heart' },
        ],
      };
      DOORS.unshift(newDoor);
      renderGalleryV6();
      showToast(`"${newDoor.title}" added to library`);
    });
    fi.click();
  });

  function renderGalleryV6() {
    const filtered = DOORS.filter(d => {
      if (searchQuery && !(d.title.toLowerCase().includes(searchQuery) || d.genre.toLowerCase().includes(searchQuery) || d.desc.toLowerCase().includes(searchQuery) || d.tags.some(t => t.includes(searchQuery)))) return false;
      if (activeFilter !== 'All' && !d.tags.includes(activeFilter)) return false;
      return true;
    });
    if (filtered.length === 0) {
      gridV6.innerHTML = `<div style="grid-column:1/-1; padding:60px 0; text-align:center; color:var(--text-2);"><div style="font-size:32px; opacity:.4;">∅</div><div style="margin-top:8px;">No scenes match "${searchQuery}"</div></div>`;
      return;
    }
    gridV6.innerHTML = filtered.map(d => {
      const isYouTube = d.source === 'youtube' && d.youtubeId;
      const live = d.source === 'youtube';
      const dur = `${Math.floor(d.duration/60)}:${String(d.duration%60).padStart(2,'0')}`;
      return `
        <div class="door-card-v6" data-door="${d.id}">
          <div class="thumb">
            ${isYouTube
              ? `<iframe src="https://www.youtube.com/embed/${d.youtubeId}?autoplay=0&mute=1&controls=0&loop=1&playlist=${d.youtubeId}&modestbranding=1" loading="lazy" allow="autoplay" frameborder="0"></iframe>`
              : makeDoorPosterSVG(d.poster, d.accent, d.accent2)
            }
            ${live ? `<div class="live-pill"><span class="dot"></span>LIVE FEED</div>` : ''}
            <div class="duration-pill">${dur}</div>
            <div class="play-overlay-v6"><div class="circle"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 4l14 8-14 8z"/></svg></div></div>
          </div>
          <div class="meta-v6">
            <h3>${d.title}</h3>
            <div class="desc">${d.desc}</div>
            <div class="row">
              <span class="tag">${d.genre.split(' · ')[0]}</span>
              <span class="source ${isYouTube ? 'youtube' : ''}">${isYouTube ? '▶ YouTube' : (d.source === 'local' ? '⬆ Uploaded' : '🎞 Wikimedia')}</span>
            </div>
          </div>
        </div>`;
    }).join('');
    gridV6.querySelectorAll('.door-card-v6').forEach(card => {
      card.addEventListener('click', () => openDoor(card.dataset.door));
    });
  }
  renderGalleryV6();

  // ====== STATE for active detail ======
  let detailDispose = null;

  function openDoor(id) {
    const door = DOORS.find(x => x.id === id); if (!door) return;
    galleryEl.style.display = 'none';
    detail.style.display = 'grid';
    const tpl = document.getElementById('doors-detail-template');
    detail.innerHTML = '';
    detail.appendChild(tpl.content.cloneNode(true));
    setupDetail(door);
  }
  function backToGallery() {
    if (detailDispose) detailDispose();
    detailDispose = null;
    detail.innerHTML = '';
    detail.style.display = 'none';
    galleryEl.style.display = 'block';
  }

  // ====== Per-drone editing state (persists per session per door) ======
  // Key: drone index 0..N-1; Value: { color: '#xxx', behavior: 'auto'|'static'|'pulse'|'orbit' }
  function setupDetail(door) {
    document.getElementById('dd-title').textContent = door.title;
    document.getElementById('dd-genre').textContent = door.genre;
    document.getElementById('dd-duration').textContent = `${Math.floor(door.duration/60)}:${String(door.duration%60).padStart(2,'0')}`;
    document.getElementById('doors-back').addEventListener('click', backToGallery);

    // ----- VIDEO ELEMENT (real, with YouTube/HTML5/SVG fallback chain) -----
    const stage = document.getElementById('dd-video-stage');
    let videoEl = null;
    let ytIframe = null;
    let videoLoaded = false;
    let usingFallback = false;

    if (door.source === 'youtube' && door.youtubeId) {
      // YouTube iframe — use IFrame API for play/pause/seek when available
      ytIframe = document.createElement('iframe');
      ytIframe.src = `https://www.youtube.com/embed/${door.youtubeId}?enablejsapi=1&autoplay=1&mute=1&controls=0&loop=1&playlist=${door.youtubeId}&modestbranding=1&rel=0`;
      ytIframe.allow = 'autoplay; encrypted-media';
      ytIframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';
      stage.appendChild(ytIframe);
      // We don't know if the embed succeeded; leave fallback below in case
      stage.insertAdjacentHTML('beforeend', makeDoorAnimatedFallback(door));
      const fb = stage.querySelector('.video-svg-fallback');
      fb.style.display = 'none'; // hide unless YouTube fails
      // No load event for iframe content — assume working after 5s
      setTimeout(() => { videoLoaded = true; }, 1500);
    } else if (door.videoUrl) {
      videoEl = document.createElement('video');
      videoEl.src = door.videoUrl;
      videoEl.muted = true; videoEl.playsInline = true; videoEl.loop = true; videoEl.preload = 'metadata';
      stage.appendChild(videoEl);
      stage.insertAdjacentHTML('beforeend', makeDoorAnimatedFallback(door));
      const fb = stage.querySelector('.video-svg-fallback');
      videoEl.addEventListener('loadeddata', () => { videoLoaded = true; fb.style.display = 'none'; });
      videoEl.addEventListener('error', () => { usingFallback = true; videoEl.style.display = 'none'; });
      setTimeout(() => { if (!videoLoaded) { usingFallback = true; videoEl.style.display = 'none'; } }, 4500);
    } else {
      stage.insertAdjacentHTML('beforeend', makeDoorAnimatedFallback(door));
      usingFallback = true;
    }

    // ----- VIRTUAL CLOCK -----
    const ddClock = { t: 0, playing: true, duration: door.duration };
    function setPlaying(on) {
      ddClock.playing = on;
      const playBtn = document.getElementById('dd-play');
      if (playBtn) playBtn.textContent = on ? '❚❚' : '▶';
      const scan = document.getElementById('dd-scan-line');
      if (scan) scan.classList.toggle('active', on);
      if (videoEl && !usingFallback) {
        if (on) videoEl.play().catch(() => {});
        else videoEl.pause();
      } else if (ytIframe) {
        try {
          ytIframe.contentWindow.postMessage(JSON.stringify({
            event: 'command', func: on ? 'playVideo' : 'pauseVideo', args: []
          }), '*');
        } catch (e) {}
      }
    }
    document.getElementById('dd-play').addEventListener('click', () => setPlaying(!ddClock.playing));
    document.getElementById('dd-back-5').addEventListener('click', () => seek(Math.max(0, ddClock.t - 5)));
    document.getElementById('dd-fwd-5').addEventListener('click', () => seek(Math.min(door.duration, ddClock.t + 5)));
    document.getElementById('dd-progress').addEventListener('click', (e) => {
      const r = e.currentTarget.getBoundingClientRect();
      seek(((e.clientX - r.left) / r.width) * door.duration);
    });
    document.getElementById('dd-mute').addEventListener('click', (e) => {
      if (videoEl) { videoEl.muted = !videoEl.muted; e.currentTarget.textContent = videoEl.muted ? '🔇' : '🔊'; }
      else if (ytIframe) {
        try {
          ytIframe.contentWindow.postMessage(JSON.stringify({ event: 'command', func: 'unMute', args: [] }), '*');
        } catch (e) {}
        e.currentTarget.textContent = '🔊';
      }
    });
    document.getElementById('dd-fullscreen').addEventListener('click', () => {
      const el = document.querySelector('.detail-pane.video-pane');
      if (el && el.requestFullscreen) el.requestFullscreen();
    });
    document.getElementById('dd-reset-detect').addEventListener('click', () => { seek(0); resetLog(); droneEdits.clear(); refreshSwarmColors(); });

    document.getElementById('dd-bake-show').addEventListener('click', () => {
      const clips = [];
      let id = 100, cursor = 0;
      door.detections.forEach(d => {
        const dur = Math.min(5, d.life);
        if (formations[d.droneFormation]) {
          clips.push({ id: id++, formation: d.droneFormation, name: d.obj, color: COLOR_MAP[d.color] || '#ff8c1a', start: cursor, dur, kind: 'preset' });
          cursor += dur;
        }
      });
      if (clips.length) { app.ch.clips = clips.slice(0, 6); showToast(`Baked ${clips.length} formations into Choreography`); }
    });

    function seek(t) {
      ddClock.t = t;
      if (videoEl && !usingFallback && videoLoaded) videoEl.currentTime = t;
      if (ytIframe) {
        try { ytIframe.contentWindow.postMessage(JSON.stringify({ event: 'command', func: 'seekTo', args: [t, true] }), '*'); } catch (e) {}
      }
      activeDetections = door.detections.filter(d => t >= d.t && t < d.t + d.life).map(d => ({ ...d, _firstSeen: t }));
      firedSet = new Set(door.detections.filter(d => t >= d.t).map(d => d.t));
      renderActiveBoxes(); renderActiveList();
    }
    function tick(dt) {
      if (videoEl && !usingFallback && videoLoaded && !videoEl.paused) {
        ddClock.t = videoEl.currentTime;
        if (ddClock.t >= door.duration) { ddClock.t = 0; videoEl.currentTime = 0; }
      } else if (ddClock.playing) {
        ddClock.t += dt / 1000;
        if (ddClock.t >= door.duration) { ddClock.t = 0; resetLog(); }
      }
      const pct = (ddClock.t / door.duration) * 100;
      const fill = document.getElementById('dd-progress-fill');
      if (fill) fill.style.width = pct + '%';
      const m = Math.floor(ddClock.t/60), s = Math.floor(ddClock.t%60);
      const tm = Math.floor(door.duration/60), ts = Math.floor(door.duration%60);
      const tc = document.getElementById('dd-timecode');
      if (tc) tc.textContent = `${m}:${String(s).padStart(2,'0')} / ${tm}:${String(ts).padStart(2,'0')}`;
    }

    // ----- DETECTIONS -----
    let firedSet = new Set();
    let activeDetections = [];
    const detLog = [];
    const COLOR_MAP = { orange: '#ff8c1a', cyan: '#4dd0e1', pink: '#ff80ab', green: '#66bb6a', purple: '#b388ff' };

    function checkDetections() {
      door.detections.forEach(d => {
        if (ddClock.t >= d.t && !firedSet.has(d.t)) {
          firedSet.add(d.t);
          activeDetections.push({ ...d, _firstSeen: ddClock.t });
          detLog.unshift({ t: d.t, obj: d.obj, formation: d.droneFormation, conf: d.conf });
          renderLog();
          triggerSwarmMorph(d);
        }
      });
      const before = activeDetections.length;
      activeDetections = activeDetections.filter(d => ddClock.t < d.t + d.life);
      renderActiveBoxes(); if (before !== activeDetections.length) renderActiveList();
      const dc = document.getElementById('dd-det-count');
      const sd = document.getElementById('dd-stat-detected');
      const sc = document.getElementById('dd-stat-converted');
      if (dc) dc.textContent = activeDetections.length;
      if (sd) sd.textContent = firedSet.size;
      if (sc) sc.textContent = detLog.length;
    }
    function renderActiveBoxes() {
      const overlay = document.getElementById('dd-yolo-overlay');
      if (!overlay) return;
      overlay.innerHTML = activeDetections.map(d => {
        const age = ddClock.t - d._firstSeen;
        const fadeIn = Math.min(1, age / 0.3);
        const fadeOut = Math.min(1, (d.life - age) / 0.5);
        const opacity = Math.min(fadeIn, fadeOut);
        return `<div class="yolo-box color-${d.color}" style="left:${d.box.x}%; top:${d.box.y}%; width:${d.box.w}%; height:${d.box.h}%; opacity:${opacity};">
          <div class="yolo-label">${d.obj} <span class="conf">${(d.conf*100).toFixed(0)}%</span></div>
        </div>`;
      }).join('');
    }
    function renderActiveList() {
      const list = document.getElementById('dd-active-list'); if (!list) return;
      if (activeDetections.length === 0) {
        list.innerHTML = `<div style="color:var(--text-3); font-size:10.5px; padding:8px 0;">${ddClock.playing ? 'Scanning… no objects in frame' : 'Press play to start scanning…'}</div>`;
        return;
      }
      list.innerHTML = activeDetections.map(d => `
        <div class="det-item active">
          <div class="dot" style="color:${COLOR_MAP[d.color]}; background:${COLOR_MAP[d.color]};"></div>
          <div>
            <div class="name">${d.obj}</div>
            <div class="conf-bar"><div class="fill" style="width:${d.conf*100}%; background:${COLOR_MAP[d.color]};"></div></div>
            <div class="meta">→ ${d.droneFormation} formation · ${(d.conf*100).toFixed(1)}% conf</div>
          </div>
          <div class="conf">${(d.conf*100).toFixed(0)}%</div>
        </div>
      `).join('');
      const top = activeDetections[activeDetections.length - 1];
      if (top) document.getElementById('dd-active-formation').innerHTML = `${top.droneFormation} <span class="conf">${(top.conf*100).toFixed(0)}%</span>`;
    }
    function renderLog() {
      const logEl = document.getElementById('dd-log'); if (!logEl) return;
      logEl.innerHTML = detLog.slice(0, 12).map(e => `
        <div class="log-entry">
          <span class="ts">+${e.t.toFixed(1)}s</span>
          <span class="msg">Detected <span class="obj">${e.obj}</span> → swarm formed <span class="form">${e.formation}</span> (${(e.conf*100).toFixed(0)}%)</span>
        </div>
      `).join('');
    }
    function resetLog() {
      detLog.length = 0; firedSet.clear(); activeDetections = [];
      renderLog(); renderActiveList(); renderActiveBoxes();
    }

    // ----- DRONE SCENE — clamped to 30..100 -----
    const canvas = document.getElementById('dd-canvas');
    const renderer = makeRendererForCanvas(canvas);
    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x040608, 0.014);
    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 200);
    makeNightSky(scene); makeGroundGrid(scene, 40);
    scene.add(new THREE.AmbientLight(0x4a5a7a, 0.5));
    const dl = new THREE.DirectionalLight(0xa8c8ff, 0.7); dl.position.set(8,12,5); scene.add(dl);
    const fillLight = new THREE.DirectionalLight(new THREE.Color(door.accent).getHex(), 0.25); fillLight.position.set(-6,4,-8); scene.add(fillLight);
    const orbit = attachOrbitControls(canvas, camera, { dist: 16, target: new THREE.Vector3(0,2,0), elev: 0.3 });

    // 30..100 — pick a smart default (60 for trophies, 50 for theatre, 80 for sports)
    const N = Math.max(30, Math.min(100, door.detections.length > 6 ? 80 : 50));
    const droneCountEl = document.getElementById('dd-drone-count');
    if (droneCountEl) droneCountEl.textContent = N;

    const dots = []; const glows = [];
    const swarmGroup = new THREE.Group(); scene.add(swarmGroup);
    for (let i = 0; i < N; i++) {
      const c = new THREE.Color(door.accent);
      const mesh = new THREE.Mesh(new THREE.SphereGeometry(0.10, 12, 8), new THREE.MeshBasicMaterial({ color: c }));
      mesh.userData.droneIdx = i;
      swarmGroup.add(mesh); dots.push(mesh);
      const glow = new THREE.Sprite(new THREE.SpriteMaterial({ map: glowTexture, color: c, transparent: true, blending: THREE.AdditiveBlending, depthWrite: false, opacity: 0.8 }));
      glow.scale.set(0.7, 0.7, 1);
      swarmGroup.add(glow); glows.push(glow);
    }

    // Per-drone overrides
    const droneEdits = new Map(); // idx -> { color, behavior }

    let currentColor = new THREE.Color(door.accent);
    let prevPositions = formations.circle(N);
    let nextPositions = formations.circle(N);
    let morphStart = 0, morphDuration = 1.2;
    let morphOrder = nextPositions.map((_, i) => i);
    let prevColor = currentColor.clone();
    let nextColor = currentColor.clone();

    function triggerSwarmMorph(detection) {
      const fName = formations[detection.droneFormation] ? detection.droneFormation : 'circle';
      const target = formations[fName](N);
      const cur = dots.map(d => [d.position.x, d.position.y, d.position.z]);
      prevPositions = cur; nextPositions = target;
      morphOrder = matchPoints(cur, target);
      morphStart = performance.now() / 1000;
      morphDuration = 1.4;
      prevColor = currentColor.clone();
      nextColor = new THREE.Color(COLOR_MAP[detection.color] || door.accent);
      currentColor = nextColor.clone();
    }

    const startPts = formations.circle(N);
    startPts.forEach((p, i) => { dots[i].position.set(p[0],p[1],p[2]); glows[i].position.set(p[0],p[1],p[2]); });

    function updateSwarm(now) {
      const t = (now/1000 - morphStart) / morphDuration;
      const eased = Math.min(1, Math.max(0, t*t*(3-2*t)));
      const colorMix = prevColor.clone().lerp(nextColor, eased);
      for (let i = 0; i < N; i++) {
        const a = prevPositions[i % prevPositions.length];
        const b = nextPositions[morphOrder[i] % nextPositions.length];
        let x = a[0] + (b[0]-a[0])*eased;
        let y = a[1] + (b[1]-a[1])*eased + Math.sin(eased*Math.PI)*0.4;
        let z = a[2] + (b[2]-a[2])*eased;
        const bob = Math.sin(now*0.001 + i*0.3)*0.04;
        const edit = droneEdits.get(i);
        // Behaviors
        if (edit && edit.behavior) {
          if (edit.behavior === 'pulse') {
            const p = 0.85 + 0.15*Math.sin(now*0.005 + i);
            x *= p; y = y * p + bob; z *= p;
          } else if (edit.behavior === 'orbit') {
            const ang = now*0.001 + i*0.5;
            const r = 0.5;
            x += Math.cos(ang) * r; z += Math.sin(ang) * r;
          } else if (edit.behavior === 'static') {
            // Use last morphed position; freeze bob/jitter
          } else { y += bob; }
        } else { y += bob; }
        dots[i].position.set(x, y, z);
        glows[i].position.set(x, y, z);
        const finalColor = (edit && edit.color) ? new THREE.Color(edit.color) : colorMix;
        dots[i].material.color.copy(finalColor);
        glows[i].material.color.copy(finalColor);
      }
      // Selected drone marker on screen
      if (selectedDroneIdx !== null && pickMarker) {
        const v = dots[selectedDroneIdx].position.clone().project(camera);
        const rect = canvas.getBoundingClientRect();
        const sx = (v.x + 1)/2 * rect.width;
        const sy = (-v.y + 1)/2 * rect.height;
        if (v.z < 1) {
          pickMarker.style.display = 'block';
          pickMarker.style.left = sx + 'px';
          pickMarker.style.top = sy + 'px';
