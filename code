    dronePane.appendChild(editPanel);

    // Pick on click
    let downX = 0, downY = 0;
    canvas.addEventListener('mousedown', (e) => { if (e.button===0) { downX = e.clientX; downY = e.clientY; }});
    canvas.addEventListener('mouseup', (e) => {
      if (e.button !== 0) return;
      if (Math.abs(e.clientX - downX) > 5 || Math.abs(e.clientY - downY) > 5) return;
      const rect = canvas.getBoundingClientRect();
      let best = -1, bd = Infinity;
      for (let i = 0; i < N; i++) {
        const v = dots[i].position.clone().project(camera);
        if (v.z >= 1) continue;
        const sx = (v.x + 1)/2 * rect.width;
        const sy = (-v.y + 1)/2 * rect.height;
        const dx = sx - (e.clientX - rect.left), dy = sy - (e.clientY - rect.top);
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist < 24 && dist < bd) { bd = dist; best = i; }
      }
      if (best >= 0) selectDrone(best);
      else { editPanel.classList.remove('visible'); selectedDroneIdx = null; pickMarker.style.display = 'none'; }
    });

    function selectDrone(idx) {
      selectedDroneIdx = idx;
