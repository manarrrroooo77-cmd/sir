  const cats = ['All', ...new Set(LIBRARY.map(x => x.category))];
  let activeCat = 'All';
  filters.innerHTML = cats.map(c => `<div class="lib-filter-chip ${c === activeCat ? 'active' : ''}" data-cat="${c}">${c}</div>`).join('');
  filters.querySelectorAll('.lib-filter-chip').forEach(chip => {
