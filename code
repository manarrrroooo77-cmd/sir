function memberById(id) {
  if (id === 'me') return collabState.me;
  return collabState.teammates.find(t => t.id === id);
}

// ============== PAGE: COLLABORATION ==============
function initCollab() {
  const root = stage.querySelector('.page[data-page="collab"]');
  if (!root) return;

  const myAvatar = makeMemoji(collabState.me.seed);

  // ---- Sidebar: members + activity ----
  function renderMembers() {
    const active = document.getElementById('collab-active-members');
    const all = document.getElementById('collab-all-members');
    const meAndActive = [collabState.me, ...collabState.teammates];
    active.innerHTML = meAndActive.map(m => {
      const isMe = m.id === 'me';
      const status = isMe ? 'editing' : (m.status || 'online');
      const role = isMe ? 'You · ' + m.role : m.role;
      return `<div class="member-row" data-member="${m.id}">
        <div class="avatar">${makeMemoji(m.seed)}<div class="status-dot ${status}"></div></div>
        <div class="info"><div class="name">${m.name}</div><div class="role">${role}</div></div>
        <div class="access-pill ${m.access}">${m.access}</div>
      </div>`;
    }).join('');
    all.innerHTML = `<div class="member-row" style="opacity:.55; cursor:default;">
      <div class="avatar" style="background: var(--bg-3); border-radius: 50%; display:flex; align-items:center; justify-content:center; color: var(--text-3); font-size:14px;">+2</div>
      <div class="info"><div class="name">2 invited members</div><div class="role">Pending acceptance</div></div>
    </div>`;
  }
  renderMembers();

  function addActivity(authorId, what) {
    collabState.activity.unshift({ authorId, what, t: Date.now() });
    if (collabState.activity.length > 16) collabState.activity.pop();
    const feed = document.getElementById('collab-activity-feed');
    if (!feed) return;
    feed.innerHTML = collabState.activity.slice(0, 8).map(a => {
      const m = memberById(a.authorId);
      const minAgo = Math.max(0, Math.floor((Date.now() - a.t) / 60000));
      return `<div class="activity-row">
        <div class="av-mini">${makeMemoji(m.seed)}</div>
        <div>
          <div class="msg"><span class="who">${m.id === 'me' ? 'You' : m.name.split(' ')[0]}</span> <span class="what">${a.what}</span></div>
          <div class="ts">${minAgo === 0 ? 'just now' : minAgo + 'm ago'}</div>
        </div>
      </div>`;
    }).join('');
  }

  // ---- Top floating presence bar ----
  function renderPresenceBar() {
    const bar = document.getElementById('collab-presence-bar');
    bar.innerHTML = collabState.teammates.map(t => `
      <div class="presence-pill ${t.status === 'editing' ? 'editing' : ''}" data-member="${t.id}">
        <div class="avatar-mini">${makeMemoji(t.seed)}<div class="status-dot ${t.status}"></div></div>
        <div>
          <div class="name">${t.name.split(' ')[0]}</div>
          <div class="status-text">${t.status === 'editing' ? 'editing now' : t.status === 'idle' ? 'idle 2m' : 'viewing'}</div>
        </div>
      </div>
    `).join('') + `
      <div class="divider"></div>
      <button class="invite-btn" id="invite-btn">
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l5 6h-3v8H6V7H3z"/></svg>
        Share
      </button>`;
    document.getElementById('invite-btn').addEventListener('click', openShareModal);
  }
  renderPresenceBar();

  // ---- 3D workspace canvas: simplified swarm preview ----
  const canvas = document.getElementById('collab-canvas');
  const renderer = makeRendererForCanvas(canvas);
  const scene = new THREE.Scene();
  scene.fog = new THREE.FogExp2(0x040608, 0.012);
  const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 200);
  makeNightSky(scene); makeGroundGrid(scene, 40);
  scene.add(new THREE.AmbientLight(0x4a5a7a, 0.5));
  const dl = new THREE.DirectionalLight(0xa8c8ff, 0.6); dl.position.set(8,12,5); scene.add(dl);
  const orbit = attachOrbitControls(canvas, camera, { dist: 18, target: new THREE.Vector3(0,2,0), elev: 0.3 });

  // Build dot swarm from app.swarm
  const dots = []; const glows = [];
  const swarmGroup = new THREE.Group(); scene.add(swarmGroup);
  app.swarm.drones.forEach(d => {
    const c = new THREE.Color(d.color);
    const m = new THREE.Mesh(new THREE.SphereGeometry(0.10, 12, 8), new THREE.MeshBasicMaterial({ color: c }));
    m.position.set(d.x, d.y, d.z);
    swarmGroup.add(m); dots.push(m);
    const g = new THREE.Sprite(new THREE.SpriteMaterial({ map: glowTexture, color: c, transparent: true, blending: THREE.AdditiveBlending, depthWrite: false, opacity: .8 }));
    g.scale.set(0.7, 0.7, 1); g.position.copy(m.position);
    swarmGroup.add(g); glows.push(g);
  });

  function resize() {
    const w = canvas.parentElement.clientWidth, h = canvas.parentElement.clientHeight;
    renderer.setSize(w, h, false); camera.aspect = w/h; camera.updateProjectionMatrix();
  }
  resize();
  const onResize = () => resize();
  window.addEventListener('resize', onResize);

  // ---- Floating teammate avatars + cursors in workspace ----
  const workspaceEl = document.querySelector('.collab-workspace');
  const teammates = collabState.teammates;

  // Cursor positions (% of workspace) — simulated random walk
  const cursorPositions = teammates.map((t, i) => ({
    x: 30 + i * 20, y: 40 + i * 8,
    targetX: 30 + i * 20, targetY: 40 + i * 8,
    nextChange: 0,
  }));

  // Floating avatar elements
  const floatingAvatars = teammates.map((t) => {
    const el = document.createElement('div');
    el.className = 'floating-avatar';
    el.style.setProperty('--ring-color', t.color);
    el.innerHTML = `
      <div class="ring">${makeMemoji(t.seed)}</div>
      <div class="name-tag">${t.name.split(' ')[0]}</div>
      <div class="activity-tag" id="activity-${t.id}">${t.activity}</div>
    `;
    workspaceEl.appendChild(el);
    return el;
  });

  // Cursor elements
  const cursorEls = teammates.map((t) => {
    const el = document.createElement('div');
    el.className = 'live-cursor';
    el.style.setProperty('--ring-color', t.color);
    el.innerHTML = `
      <svg viewBox="0 0 24 24"><path d="M3 2l16 8-7 2-2 7z" fill="${t.color}" stroke="white" stroke-width="1"/></svg>
      <div class="label" style="background:${t.color};">${t.name.split(' ')[0]}</div>
    `;
    workspaceEl.appendChild(el);
    return el;
  });

  // Drone "owner" markers — show who's editing which drone
  const ownerMarkers = new Map(); // teammateId -> { el, droneIdx }

  // ---- Comments + reactions ----
  const myAvatarInputEl = document.getElementById('my-avatar-input');
  if (myAvatarInputEl) myAvatarInputEl.innerHTML = makeMemoji(collabState.me.seed);

  function renderComments() {
    const list = document.getElementById('comments-list');
    if (!list) return;
    list.innerHTML = collabState.comments.map(c => {
      const author = memberById(c.authorId);
      const reactions = Object.entries(c.reactions || {});
      return `<div class="comment">
        <div class="avatar">${makeMemoji(author.seed)}</div>
        <div class="body">
          <div class="header">
            <span class="author" style="${c.authorId === 'me' ? 'color: var(--accent);' : ''}">${c.authorId === 'me' ? 'You' : author.name}</span>
            <span class="time">${timeAgo(c.minutesAgo)}</span>
          </div>
          ${c.target ? `<div class="target">↳ ${c.target}</div>` : ''}
          <div class="text">${c.text}</div>
          ${reactions.length ? `<div class="reactions">${reactions.map(([emoji, users]) => `
            <div class="reaction-chip ${users.includes('me') ? 'mine' : ''}" data-c="${c.id}" data-e="${emoji}">${emoji} <span class="count">${users.length}</span></div>
          `).join('')}</div>` : ''}
        </div>
      </div>`;
    }).join('');
    // Wire reaction toggles
    list.querySelectorAll('.reaction-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const cid = parseInt(chip.dataset.c);
        const emoji = chip.dataset.e;
        const c = collabState.comments.find(x => x.id === cid);
        if (!c) return;
        c.reactions[emoji] = c.reactions[emoji] || [];
        const idx = c.reactions[emoji].indexOf('me');
        if (idx >= 0) c.reactions[emoji].splice(idx, 1);
        else c.reactions[emoji].push('me');
        if (c.reactions[emoji].length === 0) delete c.reactions[emoji];
        renderComments();
      });
    });
  }
  renderComments();

  // Comment input
  const input = document.getElementById('comment-input');
  const sendBtn = document.getElementById('comment-send');
  input.addEventListener('input', () => {
    sendBtn.disabled = !input.value.trim();
  });
  function sendComment() {
    const text = input.value.trim(); if (!text) return;
    collabState.comments.unshift({ id: collabState.nextCommentId++, authorId: 'me', text, target: null, minutesAgo: 0, reactions: {} });
    input.value = ''; sendBtn.disabled = true;
    renderComments(); addActivity('me', `posted a comment`);
    // Trigger a "Noor likes your comment" reaction after a delay
    setTimeout(() => {
      const c = collabState.comments.find(c => c.id === collabState.nextCommentId - 1);
      if (c) {
        c.reactions['👍'] = c.reactions['👍'] || []; c.reactions['👍'].push('noor');
        renderComments();
      }
    }, 2500);
  }
  sendBtn.addEventListener('click', sendComment);
  input.addEventListener('keydown', (e) => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendComment(); }});

  // Comments tabs
  document.querySelectorAll('.comments-tabs .tab-pill').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.comments-tabs .tab-pill').forEach(x => x.classList.toggle('active', x === tab));
      const list = document.getElementById('comments-list');
      if (tab.dataset.commentsTab === 'comments') renderComments();
      else {
        // Show activity feed
        list.innerHTML = collabState.activity.length === 0
          ? '<div style="color: var(--text-3); font-size: 11px; padding: 20px 0; text-align: center;">No activity yet — try interacting with a teammate</div>'
          : collabState.activity.map(a => {
            const m = memberById(a.authorId);
            const minAgo = Math.max(0, Math.floor((Date.now() - a.t) / 60000));
            return `<div class="activity-row">
              <div class="av-mini">${makeMemoji(m.seed)}</div>
              <div>
                <div class="msg"><span class="who">${m.id === 'me' ? 'You' : m.name.split(' ')[0]}</span> <span class="what">${a.what}</span></div>
                <div class="ts">${minAgo === 0 ? 'just now' : minAgo + 'm ago'}</div>
              </div>
            </div>`;
          }).join('');
      }
    });
  });

  // ---- Quick reactions ----
  workspaceEl.querySelectorAll('.react-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      spawnReaction(btn.dataset.reaction, '50%', '70%');
      addActivity('me', `reacted with ${btn.dataset.reaction}`);
    });
  });
  function spawnReaction(emoji, x, y) {
    const el = document.createElement('div');
    el.className = 'reaction-burst';
    el.textContent = emoji;
    el.style.left = x; el.style.top = y;
    workspaceEl.appendChild(el);
    setTimeout(() => el.remove(), 2400);
  }

  // ---- Voice toggle ----
  const voiceBtn = document.getElementById('collab-voice');
  voiceBtn.addEventListener('click', () => {
    collabState.voiceOn = !collabState.voiceOn;
    voiceBtn.classList.toggle('active', collabState.voiceOn);
    voiceBtn.querySelector('span').textContent = collabState.voiceOn ? 'Live' : 'Voice';
    if (collabState.voiceOn) {
      addActivity('me', 'started voice chat');
      // Simulate: after 2s, Noor joins the call
      setTimeout(() => {
        if (collabState.voiceOn) showSpeechBubble('noor', 'Hey — joining you now', 5000);
      }, 2200);
    }
  });

  // ---- Speech bubbles ----
  const activeBubbles = new Map();
  function showSpeechBubble(memberId, text, durationMs = 5000) {
    const t = collabState.teammates.find(x => x.id === memberId); if (!t) return;
    // Remove any existing bubble for this member
    const existing = activeBubbles.get(memberId);
    if (existing) existing.remove();
    const bubble = document.createElement('div');
    bubble.className = 'speech-bubble';
    bubble.style.setProperty('--ring-color', t.color);
    bubble.innerHTML = `<div class="speaker"><span class="voice-dot"></span>${t.name.split(' ')[0]}</div><div>${text}</div>`;
    workspaceEl.appendChild(bubble);
    activeBubbles.set(memberId, bubble);
    // Position is set by avatar update loop
    setTimeout(() => { bubble.remove(); activeBubbles.delete(memberId); }, durationMs);
  }

  // ---- Drone owner markers ----
  function showOwnerMarker(memberId, droneIdx) {
    const t = collabState.teammates.find(x => x.id === memberId); if (!t || !dots[droneIdx]) return;
    const existing = ownerMarkers.get(memberId);
    if (existing) existing.el.remove();
    const el = document.createElement('div');
    el.className = 'drone-owner-marker';
    el.style.setProperty('--ring-color', t.color);
    el.innerHTML = `<div class="ring"></div><div class="avatar-mini">${makeMemoji(t.seed)}</div>`;
    workspaceEl.appendChild(el);
    ownerMarkers.set(memberId, { el, droneIdx });
    setTimeout(() => {
      const m = ownerMarkers.get(memberId);
      if (m && m.el === el) { el.remove(); ownerMarkers.delete(memberId); }
    }, 4500);
  }

  // ---- Bot scripts: drive each teammate's behaviour over time ----
  const startTime = performance.now();
  const scriptCursor = teammates.map(() => 0);

  function runBotTick() {
    const elapsed = performance.now() - startTime;
    teammates.forEach((t, i) => {
      const c = scriptCursor[i];
      const ev = t.script[c];
      if (ev && elapsed >= ev.delay) {
        scriptCursor[i] = c + 1;
        // Execute event
        if (ev.type === 'comment') {
          collabState.comments.unshift({ id: collabState.nextCommentId++, authorId: t.id, text: ev.text, target: ev.target, minutesAgo: 0, reactions: {} });
          renderComments();
          addActivity(t.id, `commented on ${ev.target || 'project'}`);
          // Briefly elevate to "editing"
          t.status = 'editing'; updateAvatarStatus(t);
          setTimeout(() => { t.status = t.id === 'sara' ? 'idle' : 'online'; updateAvatarStatus(t); }, 3500);
        } else if (ev.type === 'edit') {
          addActivity(t.id, ev.what);
          // Find a random drone for them to "edit"
          const droneIdx = Math.floor(Math.random() * dots.length);
          showOwnerMarker(t.id, droneIdx);
          t.status = 'editing'; updateAvatarStatus(t);
          setTimeout(() => { t.status = 'online'; updateAvatarStatus(t); }, 4000);
        } else if (ev.type === 'reaction') {
          spawnReaction(ev.emoji, cursorPositions[i].x + '%', cursorPositions[i].y + '%');
          addActivity(t.id, `reacted with ${ev.emoji}`);
        } else if (ev.type === 'speech') {
          showSpeechBubble(t.id, ev.text, 4500);
          addActivity(t.id, `said "${ev.text}"`);
        }
      }
    });
  }

  function updateAvatarStatus(t) {
    // Update presence bar pill
    const pill = document.querySelector(`.collab-presence-bar [data-member="${t.id}"]`);
    if (pill) {
      const dot = pill.querySelector('.status-dot');
      if (dot) { dot.className = 'status-dot ' + t.status; }
      const txt = pill.querySelector('.status-text');
      if (txt) txt.textContent = t.status === 'editing' ? 'editing now' : t.status === 'idle' ? 'idle' : 'viewing';
      pill.classList.toggle('editing', t.status === 'editing');
    }
    // Update sidebar
    const row = document.querySelector(`.member-row[data-member="${t.id}"] .status-dot`);
    if (row) row.className = 'status-dot ' + t.status;
    // Update floating activity tag
    const tag = document.getElementById(`activity-${t.id}`);
    if (tag) tag.textContent = t.status === 'editing' ? 'editing' : t.status === 'idle' ? 'idle' : 'viewing';
  }

  // ---- Cursor random walk + avatar position update ----
  function moveCursors(now) {
    cursorPositions.forEach((cp, i) => {
      if (now > cp.nextChange) {
        cp.targetX = 15 + Math.random() * 70;
        cp.targetY = 25 + Math.random() * 50;
        cp.nextChange = now + 2500 + Math.random() * 3000;
      }
      cp.x += (cp.targetX - cp.x) * 0.04;
      cp.y += (cp.targetY - cp.y) * 0.04;
      // Update DOM
      const cursor = cursorEls[i];
      cursor.style.left = cp.x + '%';
      cursor.style.top = cp.y + '%';
      // Floating avatar follows cursor with offset
      const av = floatingAvatars[i];
      av.style.left = (cp.x + 4) + '%';
      av.style.top = (cp.y - 8) + '%';
      // Speech bubble follows avatar
      const bub = activeBubbles.get(teammates[i].id);
      if (bub) {
        const rect = workspaceEl.getBoundingClientRect();
        bub.style.left = (rect.width * cp.x / 100 + 60) + 'px';
        bub.style.top = (rect.height * cp.y / 100 - 80) + 'px';
      }
    });
    // Update owner-marker positions (track their drone in 3D)
    ownerMarkers.forEach(({ el, droneIdx }) => {
      const dot = dots[droneIdx]; if (!dot) return;
      const v = dot.position.clone().project(camera);
      if (v.z >= 1) { el.style.display = 'none'; return; }
      const rect = canvas.getBoundingClientRect();
      el.style.display = 'block';
      el.style.left = ((v.x + 1) / 2 * rect.width) + 'px';
      el.style.top = ((-v.y + 1) / 2 * rect.height) + 'px';
    });
  }

  // ---- Share modal ----
  function openShareModal() {
    const backdrop = document.createElement('div');
    backdrop.className = 'share-modal-backdrop';
    const inviteCode = Math.random().toString(36).slice(2, 10).toUpperCase();
    const link = `https://siraj.studio/share/${inviteCode}`;
    backdrop.innerHTML = `
      <div class="share-modal">
        <h2>Share project</h2>
        <div class="sub">Invite collaborators with a link, or grant access by email.</div>
        <div class="share-link-row">
          <input type="text" value="${link}" readonly id="share-link-input">
          <button class="copy-btn" id="share-copy-btn">Copy link</button>
        </div>
        <div style="margin-top:14px; color:var(--text-2); font-size:11px;">Anyone with the link can:</div>
        <div class="share-access-row">
          <button class="access-btn" data-access="viewer">
            <div class="access-name">👁 View</div>
            <div class="access-desc">See the show, leave comments</div>
          </button>
          <button class="access-btn active" data-access="editor">
            <div class="access-name">✏️ Edit</div>
            <div class="access-desc">Modify drones, lighting, timeline</div>
          </button>
          <button class="access-btn" data-access="owner">
            <div class="access-name">★ Full</div>
            <div class="access-desc">Edit + manage members + export</div>
          </button>
        </div>
        <div class="invite-people-row">
          <input type="text" placeholder="Invite by email…" id="share-email-input">
          <button class="btn primary" id="share-email-send">Invite</button>
        </div>
        <div class="share-modal-actions">
          <button class="btn" id="share-close">Done</button>
        </div>
      </div>
    `;
    document.body.appendChild(backdrop);
    backdrop.addEventListener('click', (e) => { if (e.target === backdrop) backdrop.remove(); });
    backdrop.querySelector('#share-close').addEventListener('click', () => backdrop.remove());
    backdrop.querySelector('#share-copy-btn').addEventListener('click', () => {
      try { navigator.clipboard.writeText(link); } catch (e) {}
      backdrop.querySelector('#share-copy-btn').textContent = '✓ Copied';
      setTimeout(() => { const b = backdrop.querySelector('#share-copy-btn'); if (b) b.textContent = 'Copy link'; }, 1800);
    });
    backdrop.querySelectorAll('.access-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        backdrop.querySelectorAll('.access-btn').forEach(x => x.classList.toggle('active', x === btn));
      });
    });
    backdrop.querySelector('#share-email-send').addEventListener('click', () => {
      const email = backdrop.querySelector('#share-email-input').value.trim();
      if (!email) return;
      showToast(`Invitation sent to ${email}`);
      backdrop.querySelector('#share-email-input').value = '';
      addActivity('me', `invited ${email} as editor`);
    });
  }

  // ---- Render loop ----
  let raf = 0;
  function loop() {
    const now = performance.now();
    runBotTick();
    moveCursors(now);
    // Render the 3D swarm
    swarmGroup.rotation.y += 0.0008;
    renderer.render(scene, camera);
    raf = requestAnimationFrame(loop);
  }
  raf = requestAnimationFrame(loop);

  // Listen to my own mouse on canvas to occasionally trigger comment-target highlights
  canvas.addEventListener('mousemove', (e) => {
    // Could add live cursor for "me" but it's the local user, they see their own cursor
  });

  sceneRegistry.collab = {
    dispose: () => {
      cancelAnimationFrame(raf);
      window.removeEventListener('resize', onResize);
      orbit.dispose(); renderer.dispose();
      // Clean up DOM additions
      floatingAvatars.forEach(a => a.remove());
      cursorEls.forEach(c => c.remove());
      ownerMarkers.forEach(m => m.el.remove());
      activeBubbles.forEach(b => b.remove());
    }
  };
}


// ============== PAGE: LED SURFACE ==============
function initLedSurface() {
  const canvas = document.getElementById('led-canvas');
  if (!canvas) return;
  const renderer = makeRendererForCanvas(canvas, { clearColor: 0x040608 });
  const scene = new THREE.Scene();
  scene.fog = new THREE.FogExp2(0x040608, 0.01);
  const camera = new THREE.PerspectiveCamera(40, 1, 0.1, 100);
  // Stars (no ground, this is a hologram chamber)
  makeNightSky(scene);
  scene.add(new THREE.AmbientLight(0x4a5a7a, 0.4));
  const dl = new THREE.DirectionalLight(0xa8c8ff, 0.5); dl.position.set(5, 8, 4); scene.add(dl);
  const fillLight = new THREE.DirectionalLight(0x4dd0e1, 0.3); fillLight.position.set(-4, 2, -3); scene.add(fillLight);

  const orbit = attachOrbitControls(canvas, camera, { dist: 14, target: new THREE.Vector3(0, 0, 0), elev: 0.15, maxDist: 40 });

  // === Mesh density ===
  const COLS = 24, ROWS = 16; // Surface grid: 384 cells

  // Source formation (which we sample to color the panel)
  let sourceDrones = [];
  function setSourceDrones(drones) {
    sourceDrones = drones;
  }
  // Default: load current swarm
  setSourceDrones(app.swarm.drones.map(d => ({ x: d.x, y: d.y, z: d.z, color: d.color })));

  // === Surface mesh ===
  const surfaceGroup = new THREE.Group();
  scene.add(surfaceGroup);

  // Build a grid of point + halo sprites (one per cell) plus translucent backplate
  const cells = [];
  const cellGlows = [];
  const pointGeo = new THREE.SphereGeometry(0.05, 8, 6);
  for (let r = 0; r < ROWS; r++) {
    for (let c = 0; c < COLS; c++) {
      const mat = new THREE.MeshBasicMaterial({ color: 0x202530 });
      const m = new THREE.Mesh(pointGeo, mat);
      surfaceGroup.add(m);
      cells.push(m);
      const g = new THREE.Sprite(new THREE.SpriteMaterial({ map: glowTexture, color: 0x202530, transparent: true, blending: THREE.AdditiveBlending, depthWrite: false, opacity: 0.25 }));
      g.scale.set(0.18, 0.18, 1);
      surfaceGroup.add(g);
      cellGlows.push(g);
    }
  }

  // Translucent backplate (renders the panel as a shape)
  const backplateGeo = new THREE.PlaneGeometry(1, 1, COLS - 1, ROWS - 1);
  const backplateMat = new THREE.MeshBasicMaterial({ color: 0x0a1018, transparent: true, opacity: 0.35, side: THREE.DoubleSide });
  const backplate = new THREE.Mesh(backplateGeo, backplateMat);
  surfaceGroup.add(backplate);

  // Wireframe edges
  const edgeMat = new THREE.LineBasicMaterial({ color: 0x4dd0e1, transparent: true, opacity: 0.18 });
  const edgeGeo = new THREE.BufferGeometry();
  const edgePos = new Float32Array((COLS * (ROWS - 1) + ROWS * (COLS - 1)) * 6);
  edgeGeo.setAttribute('position', new THREE.BufferAttribute(edgePos, 3));
  const edges = new THREE.LineSegments(edgeGeo, edgeMat);
  surfaceGroup.add(edges);

  // Document: also render the "source" formation as small floating dots above the panel for reference
  const refGroup = new THREE.Group();
  surfaceGroup.add(refGroup);

  // === State ===
  const ledState = {
    curve: 'flat',
    bend: 0, twist: 0, wave: 0,
    width: 100, height: 100,
    glow: 75, psize: 100, rotate: 25,
    pattern: 'solid',
    autoRotateAngle: 0,
  };

  // === Geometry: position cells based on curve preset + sliders ===
  // Returns the (x, y, z) world position for grid cell (c, r) in [0..COLS-1] × [0..ROWS-1]
  function cellPosition(c, r) {
    // Normalised UV: u in [-0.5..0.5], v in [-0.5..0.5]
    const u = c / (COLS - 1) - 0.5;
    const v = r / (ROWS - 1) - 0.5;
    const W = (ledState.width / 100) * 8;
    const H = (ledState.height / 100) * 5;

    let x = u * W;
    let y = -v * H;  // flip so top-of-grid is +y
    let z = 0;

    const bendRad = (ledState.bend / 180) * Math.PI;

    if (ledState.curve === 'flat') {
      // straight panel; bend tilts the panel forward like a kiosk
      const tilt = bendRad * 0.5;
      const yT = y * Math.cos(tilt) - z * Math.sin(tilt);
      const zT = y * Math.sin(tilt) + z * Math.cos(tilt);
      y = yT; z = zT;
    } else if (ledState.curve === 'cylinder') {
      // wrap horizontally — bend determines wrap angle (full at 180°)
      const wrapAngle = (bendRad > 0.05 ? bendRad : 0.001) * 2; // 0..360
      const radius = W / wrapAngle;
      const theta = (u) * wrapAngle - Math.PI / 2;
      x = Math.cos(theta) * radius;
      z = Math.sin(theta) * radius + radius;
      // y unchanged
    } else if (ledState.curve === 'dome') {
      // dome: latitude ranges over the bend angle
      const halfArc = bendRad > 0.05 ? bendRad : 0.001;
      const radius = W / (2 * Math.sin(halfArc));
      const theta = u * 2 * halfArc;     // -halfArc..halfArc
      const phi   = (v + 0.5) * halfArc; // 0..halfArc (top→bottom)
      x = Math.sin(theta) * radius * Math.cos(phi);
      z = (1 - Math.cos(theta)) * radius * Math.cos(phi);
      y = -Math.sin(phi) * radius + radius * Math.sin(halfArc) * 0.5;
    } else if (ledState.curve === 'wave') {
      // sinusoidal undulation along x; bend controls amplitude
      z = Math.sin(u * Math.PI * 4) * (bendRad / Math.PI) * 1.5;
    } else if (ledState.curve === 'scroll') {
      // Curl one side back into a scroll. bend = how much is rolled.
      const t = c / (COLS - 1);
      const rollStart = 1 - (ledState.bend / 180);
      if (t > rollStart) {
        const rollT = (t - rollStart) / Math.max(0.01, 1 - rollStart);
        const radius = (1 - rollStart) * W * 0.3 + 0.6;
        const theta = rollT * Math.PI * 2;
        x = (rollStart - 0.5) * W + Math.sin(theta) * radius;
        z = (1 - Math.cos(theta)) * radius;
      }
    } else if (ledState.curve === 'sphere') {
      // Wrap into a partial sphere based on bend
      const halfArc = bendRad > 0.05 ? bendRad : 0.001;
      const theta = u * 2 * halfArc;
      const phi = v * halfArc;
      const radius = W / (2 * halfArc);
      x = Math.sin(theta) * Math.cos(phi) * radius;
      y = -Math.sin(phi) * radius;
      z = (1 - Math.cos(theta) * Math.cos(phi)) * radius;
    }

    // TWIST: rotate around the vertical (Y) axis as a function of v (height)
    if (ledState.twist > 0) {
      const tw = (ledState.twist / 180) * Math.PI * v * 2;
      const cosT = Math.cos(tw), sinT = Math.sin(tw);
      const xn = x * cosT - z * sinT;
      const zn = x * sinT + z * cosT;
      x = xn; z = zn;
    }

    // WAVE: sinusoidal local displacement along z
    if (ledState.wave > 0) {
      const amp = (ledState.wave / 100) * 0.6;
      z += Math.sin(u * Math.PI * 4 + Date.now() * 0.001) * amp;
    }

    return new THREE.Vector3(x, y, z);
  }

  // Update mesh positions every frame
  function updateMesh(now) {
    let positions = [];
    const sx = (ledState.psize / 100);

    for (let r = 0; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        const i = r * COLS + c;
        const p = cellPosition(c, r);
        cells[i].position.copy(p);
        cells[i].scale.setScalar(sx);
        cellGlows[i].position.copy(p);
        cellGlows[i].scale.set(0.18 * sx, 0.18 * sx, 1);
        cellGlows[i].material.opacity = (ledState.glow / 100) * 0.6;
        positions.push(p);
      }
    }

    // Update backplate vertices
    const bp = backplate.geometry.attributes.position.array;
    for (let r = 0; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        const i = (r * COLS + c) * 3;
        const p = positions[r * COLS + c];
        bp[i] = p.x; bp[i+1] = p.y; bp[i+2] = p.z;
      }
    }
    backplate.geometry.attributes.position.needsUpdate = true;
    backplate.geometry.computeVertexNormals();

    // Update wireframe edges
    let ei = 0;
    for (let r = 0; r < ROWS; r++) {
      for (let c = 0; c < COLS - 1; c++) {
        const a = positions[r * COLS + c];
        const b = positions[r * COLS + c + 1];
        edgePos[ei++] = a.x; edgePos[ei++] = a.y; edgePos[ei++] = a.z;
        edgePos[ei++] = b.x; edgePos[ei++] = b.y; edgePos[ei++] = b.z;
      }
    }
    for (let c = 0; c < COLS; c++) {
      for (let r = 0; r < ROWS - 1; r++) {
        const a = positions[r * COLS + c];
        const b = positions[(r + 1) * COLS + c];
        edgePos[ei++] = a.x; edgePos[ei++] = a.y; edgePos[ei++] = a.z;
        edgePos[ei++] = b.x; edgePos[ei++] = b.y; edgePos[ei++] = b.z;
      }
    }
    edges.geometry.attributes.position.needsUpdate = true;

    // Color cells based on source formation projected onto UV grid
    // For each cell, find nearest source drone in 2D (X-Y in source's bounding rect)
    // and use that drone's color, dimmed by distance
    if (sourceDrones.length > 0) {
      // Get source bounding rect (X, Y) — Z used as depth weight
      let xMin = Infinity, xMax = -Infinity, yMin = Infinity, yMax = -Infinity;
      sourceDrones.forEach(d => {
        if (d.x < xMin) xMin = d.x; if (d.x > xMax) xMax = d.x;
        if (d.y < yMin) yMin = d.y; if (d.y > yMax) yMax = d.y;
      });
      const xR = xMax - xMin || 1, yR = yMax - yMin || 1;

      for (let r = 0; r < ROWS; r++) {
        for (let c = 0; c < COLS; c++) {
          const i = r * COLS + c;
          const u = c / (COLS - 1);
          const v = 1 - r / (ROWS - 1);
          const tx = xMin + u * xR;
          const ty = yMin + v * yR;
          // Find closest source drone in (x,y)
          let best = null, bd = Infinity;
          for (const d of sourceDrones) {
            const dx = d.x - tx, dy = d.y - ty;
            const dist = dx*dx + dy*dy;
            if (dist < bd) { bd = dist; best = d; }
          }
          // Threshold for "lit" cell: within sqrt(bd) ~ 0.6 units
          const litFactor = Math.max(0, 1 - Math.sqrt(bd) * 1.2);
          let baseColor;
          if (best && litFactor > 0.05) {
            baseColor = new THREE.Color(best.color);
          } else {
            baseColor = new THREE.Color(0x080a10); // dark off pixel
          }
          // Apply pattern overlay
          let color = baseColor.clone();
          if (litFactor > 0.05) {
            if (ledState.pattern === 'ripple') {
              const phase = Math.sqrt((u-0.5)**2 + (v-0.5)**2) * 6 - now * 0.003;
              const m = 0.4 + 0.6 * (Math.sin(phase) * 0.5 + 0.5);
              color.multiplyScalar(m);
            } else if (ledState.pattern === 'rainbow') {
              const h = (u + now * 0.0001) % 1;
              color = new THREE.Color().setHSL(h, 0.7, 0.55);
            } else if (ledState.pattern === 'scan') {
              const scanY = ((now * 0.0003) % 1);
              const dist = Math.abs(v - scanY);
              const m = Math.max(0.2, 1 - dist * 4);
              color.multiplyScalar(m);
            } else if (ledState.pattern === 'sparkle') {
              if (Math.random() < 0.04) color = new THREE.Color(0xffffff);
            }
            color.multiplyScalar(0.4 + 0.6 * litFactor);
          }
          cells[i].material.color.copy(color);
          cellGlows[i].material.color.copy(color);
        }
      }
    }

    if (ledState.rotate > 0) {
      surfaceGroup.rotation.y += (ledState.rotate / 100) * 0.003;
    }
  }

  // === Wire UI ===
  document.querySelectorAll('[data-led-slider]').forEach(row => bindSlider(row, 'led-slider', (name, v) => {
    ledState[name] = v;
    if (name === 'bend') document.getElementById('led-bend-readout').textContent = v + '°';
    if (name === 'twist') document.getElementById('led-twist-readout').textContent = v + '°';
  }));
  document.querySelectorAll('.led-preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      ledState.curve = btn.dataset.curve;
      document.querySelectorAll('.led-preset-btn').forEach(x => x.classList.toggle('active', x === btn));
      document.getElementById('led-mesh-info').textContent = btn.dataset.curve;
      // Auto-set a reasonable bend for each preset
      const autoBend = { flat: 15, cylinder: 90, dome: 75, wave: 60, scroll: 90, sphere: 90 };
      const slider = document.querySelector('[data-led-slider="bend"]');
      if (slider) {
        ledState.bend = autoBend[btn.dataset.curve] ?? 0;
        const fill = slider.querySelector('.slider-fill');
        const val = slider.querySelector('.val');
        const pct = (ledState.bend / 180) * 100;
        fill.style.width = pct + '%';
        val.textContent = ledState.bend;
        document.getElementById('led-bend-readout').textContent = ledState.bend + '°';
      }
    });
  });
  document.querySelectorAll('[data-led-pattern]').forEach(b => {
    b.addEventListener('click', () => {
      ledState.pattern = b.dataset.ledPattern;
      document.getElementById('led-pattern-readout').textContent = ledState.pattern;
    });
  });

  // Source switching
  document.getElementById('led-load-current').addEventListener('click', () => {
    setSourceDrones(app.swarm.drones.map(d => ({ x: d.x, y: d.y, z: d.z, color: d.color })));
    document.getElementById('led-drone-count').textContent = sourceDrones.length;
    showToast(`Loaded ${sourceDrones.length} drones from current swarm`);
  });
  document.getElementById('led-load-riyadh').addEventListener('click', () => {
    setSourceDrones(generateRiyadhSeasonFormation());
    document.getElementById('led-drone-count').textContent = sourceDrones.length;
    showToast('Loaded Riyadh Season logo');
  });
  document.getElementById('led-load-aladdin').addEventListener('click', () => {
    setSourceDrones(formationToDrones('aladdinLamp', 70, ['#ffd54f','#ffeb3b','#fff']));
    document.getElementById('led-drone-count').textContent = sourceDrones.length;
    showToast("Loaded Aladdin's lamp");
  });
  document.getElementById('led-load-trophy').addEventListener('click', () => {
    setSourceDrones(formationToDrones('worldCupTrophy', 80, ['#ffd54f','#ff8c1a','#66bb6a']));
    document.getElementById('led-drone-count').textContent = sourceDrones.length;
    showToast('Loaded World Cup Trophy');
  });
  document.getElementById('led-load-airplane').addEventListener('click', () => {
    setSourceDrones(formationToDrones('airplane', 60, ['#80deea','#b388ff','#fff']));
    document.getElementById('led-drone-count').textContent = sourceDrones.length;
    showToast('Loaded Airplane');
  });

  document.getElementById('led-drone-count').textContent = sourceDrones.length;

  function resize() {
    const w = canvas.parentElement.clientWidth, h = canvas.parentElement.clientHeight;
    renderer.setSize(w, h, false);
    camera.aspect = w / h; camera.updateProjectionMatrix();
  }
  resize();
  const onResize = () => resize();
  window.addEventListener('resize', onResize);

  let raf = 0;
  function loop() {
    const now = performance.now();
    updateMesh(now);
    renderer.render(scene, camera);
    raf = requestAnimationFrame(loop);
  }
  raf = requestAnimationFrame(loop);

  sceneRegistry.ledsurface = {
    dispose: () => {
      cancelAnimationFrame(raf);
      window.removeEventListener('resize', onResize);
      orbit.dispose();
      renderer.dispose();
    }
  };
}


// ============== PAGE: EXPORT ==============
function initExport() {
  document.querySelectorAll('.format-card').forEach(c => {
    c.addEventListener('click', () => {
      document.querySelectorAll('.format-card').forEach(x => x.classList.remove('selected'));
      c.classList.add('selected');
    });
  });
  document.getElementById('export-go').addEventListener('click', () => {
    const sel = document.querySelector('.format-card.selected');
    showToast(`Export queued · ${sel?.dataset.fmt?.toUpperCase() || 'SKYC'}`);
  });
  sceneRegistry.export = { dispose: () => {} };
}

// ============== BOOT ==============
navigateTo('layout');
</script>
