      { id: 2, formation: 'helix',  name: 'Helix Climb',    color: '#66bb6a', start: 6,  dur: 6, kind: 'preset' },
      { id: 3, formation: 'sphere', name: 'Sphere Bloom',   color: '#4dd0e1', start: 12, dur: 6, kind: 'preset' },
      { id: 4, formation: 'star',   name: 'Star Burst',     color: '#ffd54f', start: 18, dur: 6, kind: 'preset' },
      { id: 5, formation: 'heart',  name: 'Heart Finale',   color: '#ff80ab', start: 24, dur: 6, kind: 'preset' },
    ],
    nextClipId: 6,
    selectedClipId: 1,
    playhead: 0,
    playing: false,
    pxPerSec: 80,
    activeFormation: 'circle',
  },
  // Per-drone LED settings (4 rings each)
  droneLEDs: {},
  editingDroneId: null,
  // Lighting
  lt: { mode: 'rainbow', speed: 80, intensity: 75, color: '#ff8c1a' },
};

// ============== UTIL ==============
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2200);
}

function makeGlowTexture() {
  const c = document.createElement('canvas');
  c.width = c.height = 128;
  const ctx = c.getContext('2d');
  const grad = ctx.createRadialGradient(64, 64, 0, 64, 64, 64);
  grad.addColorStop(0, 'rgba(255,255,255,1)');
  grad.addColorStop(0.2, 'rgba(255,255,255,0.6)');
  grad.addColorStop(0.5, 'rgba(255,255,255,0.15)');
  grad.addColorStop(1, 'rgba(255,255,255,0)');
  ctx.fillStyle = grad; ctx.fillRect(0, 0, 128, 128);
  const tex = new THREE.CanvasTexture(c);
  tex.minFilter = THREE.LinearFilter;
  return tex;
}
const glowTexture = makeGlowTexture();

function makeRendererForCanvas(canvas, opts={}) {
  const r = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });
  r.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  r.setClearColor(opts.clearColor ?? 0x050709, 1);
  r.outputEncoding = THREE.sRGBEncoding;
  r.toneMapping = THREE.ACESFilmicToneMapping;
  r.toneMappingExposure = 1.1;
  return r;
}
function makeNightSky(scene) {
  const skyGeo = new THREE.SphereGeometry(200, 32, 32);
  const skyMat = new THREE.ShaderMaterial({
    uniforms: { topColor: { value: new THREE.Color(0x0a1424) }, bottomColor: { value: new THREE.Color(0x040608) } },
    vertexShader: `varying vec3 vWorldPosition; void main() { vec4 wp = modelMatrix * vec4(position, 1.0); vWorldPosition = wp.xyz; gl_Position = projectionMatrix * viewMatrix * wp; }`,
    fragmentShader: `uniform vec3 topColor; uniform vec3 bottomColor; varying vec3 vWorldPosition; void main() { float h = normalize(vWorldPosition).y; gl_FragColor = vec4(mix(bottomColor, topColor, max(0.0, h)), 1.0); }`,
    side: THREE.BackSide
  });
  scene.add(new THREE.Mesh(skyGeo, skyMat));
  const sg = new THREE.BufferGeometry();
  const sp = new Float32Array(900 * 3);
  for (let i = 0; i < 900; i++) {
    const r = 100 + Math.random() * 80;
    const theta = Math.random() * Math.PI * 2;
    const phi = Math.acos(2 * Math.random() - 1);
    sp[i*3]   = r * Math.sin(phi) * Math.cos(theta);
    sp[i*3+1] = r * Math.cos(phi);
    sp[i*3+2] = r * Math.sin(phi) * Math.sin(theta);
  }
  sg.setAttribute('position', new THREE.BufferAttribute(sp, 3));
  scene.add(new THREE.Points(sg, new THREE.PointsMaterial({ color: 0xffffff, size: 0.4, transparent: true, opacity: 0.55, sizeAttenuation: true })));
}
function makeGroundGrid(scene, size=80) {
  const g = new THREE.GridHelper(size, size, 0x1a2030, 0x12181f);
  g.position.y = -2;
  scene.add(g);
  const ground = new THREE.Mesh(new THREE.PlaneGeometry(size*2, size*2), new THREE.MeshBasicMaterial({ color: 0x080a0e, transparent: true, opacity: 0.85 }));
  ground.rotation.x = -Math.PI / 2;
  ground.position.y = -2.01;
  scene.add(ground);
}

function attachOrbitControls(canvas, camera, opts={}) {
  const state = {
    target: opts.target ? opts.target.clone() : new THREE.Vector3(0, 0, 0),
    dist: opts.dist || 8,
    azim: opts.azim ?? 0,
    elev: opts.elev ?? 0.4,
    isOrbiting: false, isPanning: false,
    lastX: 0, lastY: 0,
    minDist: opts.minDist || 1,
    maxDist: opts.maxDist || 100,
  };
  function update() {
    const x = state.target.x + state.dist * Math.cos(state.elev) * Math.sin(state.azim);
    const y = state.target.y + state.dist * Math.sin(state.elev);
    const z = state.target.z + state.dist * Math.cos(state.elev) * Math.cos(state.azim);
    camera.position.set(x, y, z);
    camera.lookAt(state.target);
  }
  update();
  const onDown = (e) => {
    if (e.button === 1 || (e.button === 0 && e.shiftKey)) { state.isPanning = true; state.lastX = e.clientX; state.lastY = e.clientY; e.preventDefault(); }
    else if (e.button === 2) { state.isOrbiting = true; state.lastX = e.clientX; state.lastY = e.clientY; }
  };
  const onMove = (e) => {
    if (state.isOrbiting) {
      const dx = e.clientX - state.lastX, dy = e.clientY - state.lastY;
      state.azim -= dx * 0.005;
      state.elev = Math.max(-Math.PI/2 + 0.1, Math.min(Math.PI/2 - 0.1, state.elev + dy * 0.005));
      state.lastX = e.clientX; state.lastY = e.clientY;
      update();
    }
    if (state.isPanning) {
      const dx = e.clientX - state.lastX, dy = e.clientY - state.lastY;
      const right = new THREE.Vector3(); const up = new THREE.Vector3();
      camera.matrix.extractBasis(right, up, new THREE.Vector3());
      const f = state.dist * 0.0015;
      state.target.addScaledVector(right, -dx * f);
      state.target.addScaledVector(up, dy * f);
      state.lastX = e.clientX; state.lastY = e.clientY;
      update();
    }
  };
  const onUp = () => { state.isOrbiting = false; state.isPanning = false; };
  const onWheel = (e) => {
    e.preventDefault();
    state.dist = Math.max(state.minDist, Math.min(state.maxDist, state.dist * (1 + e.deltaY * 0.001)));
    update();
  };
  canvas.addEventListener('mousedown', onDown);
  window.addEventListener('mousemove', onMove);
  window.addEventListener('mouseup', onUp);
  canvas.addEventListener('wheel', onWheel, { passive: false });
  canvas.addEventListener('contextmenu', e => e.preventDefault());
  return {
    state, update,
    dispose: () => {
      canvas.removeEventListener('mousedown', onDown);
      window.removeEventListener('mousemove', onMove);
      window.removeEventListener('mouseup', onUp);
      canvas.removeEventListener('wheel', onWheel);
    }
  };
}

function bindSlider(row, dataKey, cb) {
  const name = row.getAttribute('data-' + dataKey);
  const min = parseFloat(row.dataset.min);
  const max = parseFloat(row.dataset.max);
  const fill = row.querySelector('.slider-fill');
  const val = row.querySelector('.val');
  let value = parseFloat(val.textContent) || min;
  const ui = () => {
    const pct = ((value - min) / (max - min)) * 100;
    fill.style.width = pct + '%';
    val.textContent = Math.round(value);
  };
  ui();
  let drag = false;
  row.addEventListener('mousedown', (e) => { drag = true; setFromEvent(e); });
  function setFromEvent(e) {
    const rect = row.getBoundingClientRect();
    const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
    value = Math.round(min + pct * (max - min));
    ui();
    if (cb) cb(name, value);
  }
  const moveH = (e) => { if (drag) setFromEvent(e); };
  const upH = () => { drag = false; };
  window.addEventListener('mousemove', moveH);
  window.addEventListener('mouseup', upH);
  row._cleanup = () => {
    window.removeEventListener('mousemove', moveH);
    window.removeEventListener('mouseup', upH);
  };
}

