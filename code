<!-- SIRAJ Studio v3 — multi-page drone show editor -->
<style>
  :root{
    --bg-0:#08090c;--bg-1:#11141a;--bg-2:#181c24;--bg-3:#21262f;--bg-4:#2c3340;
    --line:#2a3038;--line-strong:#3a424e;
    --text-0:#ecedef;--text-1:#b4bac3;--text-2:#767e8a;--text-3:#4c545f;
    --accent:#ff8c1a;--accent-soft:#ffaa55;
    --cyan:#4dd0e1;--select:#ffd54f;--danger:#ef5350;--good:#66bb6a;
    --purple:#b388ff;--pink:#ff80ab;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{height:100%;overflow:hidden;font-family:'Inter',system-ui,sans-serif;background:var(--bg-0);color:var(--text-0);-webkit-font-smoothing:antialiased}
  body{font-size:11px;user-select:none}
  button{font-family:inherit}

  .menubar{height:28px;background:linear-gradient(to bottom,var(--bg-3),var(--bg-2));border-bottom:1px solid var(--bg-0);display:flex;align-items:center;padding:0 8px;gap:2px;font-size:11px;position:relative;z-index:10}
  .logo{display:flex;align-items:center;gap:6px;padding:0 10px 0 4px;margin-right:8px;border-right:1px solid var(--line);height:100%;cursor:pointer}
  .logo-mark{width:18px;height:18px;background:radial-gradient(circle at 30% 30%,var(--accent-soft),var(--accent) 70%);border-radius:50%;box-shadow:0 0 8px rgba(255,140,26,.6),inset 0 0 4px rgba(255,255,255,.3)}
  .logo-text{font-family:'Space Grotesk','Inter',sans-serif;font-weight:600;font-size:13px;letter-spacing:.5px}
  .logo-text span{color:var(--accent);font-weight:500;font-size:11px}
  .menu-item{padding:4px 10px;border-radius:3px;cursor:default;color:var(--text-1)}
  .menu-item:hover{background:var(--bg-4);color:var(--text-0)}
  .menu-spacer{flex:1}
  .scene-name{display:flex;align-items:center;gap:6px;padding:2px 8px;background:var(--bg-1);border:1px solid var(--line);border-radius:3px;color:var(--text-1);font-size:11px}

  .tabs{height:32px;background:var(--bg-2);border-bottom:1px solid var(--bg-0);display:flex;align-items:stretch;padding:0 8px;overflow-x:auto}
  .tab{padding:0 16px;display:flex;align-items:center;gap:7px;color:var(--text-2);font-size:11.5px;cursor:pointer;border-right:1px solid transparent;border-left:1px solid transparent;position:relative;transition:color .15s;white-space:nowrap}
  .tab:hover{color:var(--text-1)}
  .tab.active{background:var(--bg-1);color:var(--text-0);border-color:var(--line)}
  .tab.active::before{content:'';position:absolute;top:0;left:-1px;right:-1px;height:2px;background:var(--accent)}
  .tab svg{width:13px;height:13px;opacity:.85}

  .stage{height:calc(100vh - 32px - 28px - 22px);position:relative;overflow:hidden}
  .page{position:absolute;inset:0;display:none;flex-direction:column}
  .page.active{display:flex}

  .breadcrumb{height:26px;background:var(--bg-1);border-bottom:1px solid var(--bg-0);display:flex;align-items:center;padding:0 12px;gap:6px;font-size:10.5px;color:var(--text-2);flex-shrink:0}
  .breadcrumb a{color:var(--text-1);cursor:pointer}
  .breadcrumb a:hover{color:var(--accent)}
  .breadcrumb .sep{color:var(--text-3)}
  .breadcrumb .current{color:var(--text-0)}

  .panel{background:var(--bg-1);border-right:1px solid var(--bg-0);overflow-y:auto;overflow-x:hidden}
  .panel.right{border-right:none;border-left:1px solid var(--bg-0)}
  .panel-section{border-bottom:1px solid var(--bg-0)}
  .panel-header{height:26px;display:flex;align-items:center;gap:6px;padding:0 10px;background:var(--bg-2);color:var(--text-1);font-size:10px;font-weight:600;letter-spacing:.6px;text-transform:uppercase;cursor:pointer;border-bottom:1px solid var(--bg-0)}
  .panel-header .chevron{width:10px;height:10px;color:var(--text-2);transition:transform .15s}
  .panel-header.collapsed .chevron{transform:rotate(-90deg)}
  .panel-header .icon{width:12px;height:12px;color:var(--accent)}
  .panel-body{padding:10px}
  .panel-body.collapsed{display:none}

  .btn{background:var(--bg-3);border:1px solid var(--line);color:var(--text-0);padding:6px 12px;border-radius:4px;font-size:11px;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;gap:6px;transition:all .1s}
  .btn:hover{background:var(--bg-4);border-color:var(--line-strong)}
  .btn.primary{background:linear-gradient(to bottom,var(--accent),#e87410);border-color:rgba(255,255,255,.1);color:white;font-weight:500}
  .btn.primary:hover{filter:brightness(1.1)}
  .btn.primary:disabled{opacity:.5;cursor:not-allowed}
  .btn.full{width:100%}
  .btn.sm{padding:4px 8px;font-size:10.5px}
  .btn-icon{width:12px;height:12px}

  .input,select,textarea{width:100%;background:var(--bg-3);border:1px solid transparent;color:var(--text-0);padding:6px 8px;border-radius:3px;font-size:11px;font-family:inherit;outline:none;transition:all .1s}
  .input:hover,select:hover,textarea:hover{background:var(--bg-4)}
  .input:focus,textarea:focus{border-color:var(--accent);background:var(--bg-2)}

  .vec3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:2px}
  .vec3-item{position:relative;background:var(--bg-3);border-radius:3px;overflow:hidden}
  .vec3-item::before{content:attr(data-axis);position:absolute;left:5px;top:50%;transform:translateY(-50%);font-size:9px;font-weight:700;color:var(--axis-color);pointer-events:none;z-index:1}
  .vec3-item[data-axis="X"]{--axis-color:#ef5350}
  .vec3-item[data-axis="Y"]{--axis-color:#66bb6a}
  .vec3-item[data-axis="Z"]{--axis-color:#42a5f5}
  .vec3-item input{background:transparent;border:none;color:var(--text-0);padding:4px 4px 4px 16px;width:100%;font-size:10.5px;font-variant-numeric:tabular-nums;text-align:right;outline:none}

  .slider-row{position:relative;background:var(--bg-3);border-radius:3px;height:22px;overflow:hidden;cursor:ew-resize}
  .slider-fill{position:absolute;inset:0;background:linear-gradient(to right,rgba(255,140,26,.4),rgba(255,140,26,.2));pointer-events:none;transition:width .05s}
  .slider-label{position:absolute;inset:0;display:flex;align-items:center;justify-content:space-between;padding:0 8px;font-size:10.5px;color:var(--text-0);pointer-events:none;font-variant-numeric:tabular-nums}
  .slider-label .name{color:var(--text-2)}

  .prop-row{display:grid;grid-template-columns:80px 1fr;gap:8px;margin-bottom:6px;align-items:center}
  .prop-row label{font-size:10.5px;color:var(--text-2);text-transform:lowercase}

  .statusbar{height:22px;background:var(--bg-2);border-top:1px solid var(--bg-0);display:flex;align-items:center;padding:0 10px;gap:14px;font-size:10.5px;color:var(--text-2)}
  .statusbar .accent{color:var(--accent)}
  .statusbar .spacer{flex:1}

  ::-webkit-scrollbar{width:8px;height:8px}
  ::-webkit-scrollbar-track{background:var(--bg-1)}
  ::-webkit-scrollbar-thumb{background:var(--bg-4);border-radius:4px}
  ::-webkit-scrollbar-thumb:hover{background:var(--line-strong)}

  .toast{position:fixed;bottom:60px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--bg-0);border:1px solid var(--accent);color:var(--text-0);padding:10px 18px;border-radius:4px;font-size:11px;box-shadow:0 8px 24px rgba(0,0,0,.5);z-index:1000;opacity:0;transition:all .3s;pointer-events:none}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

  /* ===== LAYOUT (DASHBOARD) ===== */
  .dash-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;padding:18px;flex:1;overflow:auto;background:radial-gradient(ellipse at top,#0a1018 0%,var(--bg-0) 70%);grid-auto-rows:min-content}
  .dash-hero{grid-column:1/-1;display:grid;grid-template-columns:1fr auto;align-items:center;gap:24px;padding:24px 28px;background:linear-gradient(135deg,rgba(255,140,26,.12),rgba(77,208,225,.05) 50%,transparent);border:1px solid rgba(255,140,26,.18);border-radius:8px;position:relative;overflow:hidden}
  .dash-hero::before{content:'';position:absolute;right:-50px;top:-80px;width:300px;height:300px;background:radial-gradient(circle,rgba(255,140,26,.15),transparent 60%);pointer-events:none}
  .dash-hero h1{font-family:'Space Grotesk',sans-serif;font-size:26px;font-weight:700;letter-spacing:-.5px;margin-bottom:6px}
  .dash-hero .sub{color:var(--text-1);font-size:13px}
  .dash-hero .sub span{color:var(--accent)}
  .dash-hero .actions{display:flex;gap:8px;flex-direction:column;min-width:200px}
  .dash-card{background:var(--bg-1);border:1px solid var(--line);border-radius:6px;padding:16px;display:flex;flex-direction:column;cursor:pointer;transition:all .15s}
  .dash-card:hover{border-color:var(--accent);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.4)}
  .dash-card .card-icon{width:36px;height:36px;border-radius:6px;background:linear-gradient(135deg,var(--accent),#e87410);display:flex;align-items:center;justify-content:center;color:white;margin-bottom:12px}
  .dash-card.cyan .card-icon{background:linear-gradient(135deg,var(--cyan),#0097a7)}
  .dash-card.purple .card-icon{background:linear-gradient(135deg,var(--purple),#6a1b9a)}
  .dash-card.green .card-icon{background:linear-gradient(135deg,var(--good),#1b5e20)}
  .dash-card .card-icon svg{width:18px;height:18px}
  .dash-card h3{font-family:'Space Grotesk',sans-serif;font-size:15px;font-weight:600;margin-bottom:4px}
  .dash-card .desc{color:var(--text-2);font-size:11.5px;line-height:1.5;flex:1}
  .dash-card .footer-link{color:var(--accent);font-size:10.5px;margin-top:10px;display:flex;align-items:center;gap:4px}
  .dash-stats{grid-column:1/-1;display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
  .stat-card{background:var(--bg-1);border:1px solid var(--line);border-radius:6px;padding:14px 16px}
  .stat-card .label{color:var(--text-2);font-size:10.5px;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}
  .stat-card .value{font-family:'Space Grotesk',sans-serif;font-size:22px;font-weight:600;color:var(--text-0)}
  .stat-card .value .unit{color:var(--text-3);font-size:13px;font-weight:400;margin-left:4px}
  .stat-card .delta{color:var(--good);font-size:10.5px;margin-top:2px}

  /* ===== SHARED 3-COLUMN LAYOUT ===== */
  .three-col{display:grid;grid-template-columns:280px 1fr 320px;flex:1;overflow:hidden}
  .vp{position:relative;overflow:hidden;background:#050709}
  .vp canvas{width:100%;height:100%;display:block;cursor:grab}
  .vp canvas:active{cursor:grabbing}
  .vp-overlay{position:absolute;pointer-events:none;color:var(--text-1);font-size:10.5px;font-variant-numeric:tabular-nums;text-shadow:0 1px 3px rgba(0,0,0,.8)}
  .vp-info{top:10px;right:10px;text-align:right;line-height:1.6;background:rgba(8,9,12,.7);padding:8px 12px;border-radius:4px;backdrop-filter:blur(6px);border:1px solid rgba(255,255,255,.06)}
  .vp-info .accent{color:var(--accent)}
  .vp-info .lbl{color:var(--text-2)}
  .vp-bottom-info{position:absolute;bottom:12px;left:16px;color:var(--text-2);font-size:10.5px;text-shadow:0 1px 3px rgba(0,0,0,.8);pointer-events:none}
  .toolshelf{position:absolute;top:12px;left:12px;background:var(--bg-2);border:1px solid var(--line);border-radius:4px;padding:3px;display:flex;flex-direction:column;gap:1px;z-index:5;box-shadow:0 4px 12px rgba(0,0,0,.4)}
  .tool-btn{width:32px;height:32px;background:transparent;border:none;border-radius:3px;color:var(--text-1);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .1s;position:relative}
  .tool-btn:hover{background:var(--bg-4);color:var(--text-0)}
  .tool-btn.active{background:var(--accent);color:white}
  .tool-btn svg{width:16px;height:16px}
  .tool-btn[data-tip]:hover::after{content:attr(data-tip);position:absolute;left:calc(100% + 8px);top:50%;transform:translateY(-50%);background:var(--bg-0);color:var(--text-0);padding:4px 10px;border-radius:3px;font-size:10.5px;white-space:nowrap;pointer-events:none;z-index:100;border:1px solid var(--line)}

  .struct-list{padding:6px 0}
  .struct-row{display:flex;align-items:center;padding:6px 12px;cursor:pointer;color:var(--text-1);font-size:11px;gap:8px;border-left:2px solid transparent;transition:.1s}
  .struct-row:hover{background:var(--bg-2);color:var(--text-0)}
  .struct-row.active{background:rgba(255,140,26,.08);color:var(--accent);border-left-color:var(--accent)}
  .struct-row .dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;box-shadow:0 0 6px currentColor}

  /* AI panel */
  .ai-section{background:linear-gradient(135deg,rgba(255,140,26,.06),rgba(77,208,225,.04));border-radius:4px;padding:10px;border:1px solid rgba(255,140,26,.15)}
  .ai-tabs{display:flex;background:var(--bg-3);border-radius:3px;padding:2px;margin-bottom:8px}
  .ai-tab{flex:1;padding:5px 8px;text-align:center;font-size:10.5px;color:var(--text-2);cursor:pointer;border-radius:2px}
  .ai-tab.active{background:var(--bg-1);color:var(--accent);box-shadow:0 1px 3px rgba(0,0,0,.3)}
  .ai-input{min-height:56px;resize:vertical}
  .ai-suggestions{display:flex;flex-wrap:wrap;gap:4px;margin:6px 0 8px}
  .ai-chip{background:var(--bg-3);border:1px solid var(--line);color:var(--text-1);padding:2px 8px;border-radius:10px;font-size:10px;cursor:pointer}
  .ai-chip:hover{background:var(--bg-4);color:var(--accent);border-color:var(--accent)}
  .ai-status{margin-top:8px;padding:6px 8px;background:var(--bg-1);border-radius:3px;font-size:10px;color:var(--text-2);min-height:26px;display:flex;align-items:center;gap:6px}
  .ai-status.thinking{color:var(--accent)}
  .ai-status.error{color:var(--danger)}
  .ai-status.success{color:var(--good)}
  .spinner{width:10px;height:10px;border:1.5px solid var(--text-3);border-top-color:var(--accent);border-radius:50%;animation:spin .8s linear infinite}
  @keyframes spin{to{transform:rotate(360deg)}}
  .upload-zone{border:1.5px dashed var(--line-strong);border-radius:4px;padding:16px;text-align:center;cursor:pointer;background:var(--bg-1);margin-bottom:8px}
  .upload-zone:hover{border-color:var(--accent)}
  .upload-zone svg{width:22px;height:22px;color:var(--text-2);margin-bottom:4px}
  .upload-zone .label{color:var(--text-1);font-size:11px}
  .upload-zone .sub{color:var(--text-3);font-size:9.5px;margin-top:2px}
  .upload-zone img{max-width:100%;max-height:80px;border-radius:2px}

  /* color presets */
  .color-row{display:flex;align-items:center;gap:6px}
  .color-presets{display:flex;gap:3px;flex-wrap:wrap}
  .color-preset{width:16px;height:16px;border-radius:50%;cursor:pointer;border:1px solid var(--line);transition:transform .1s}
  .color-preset:hover{transform:scale(1.15)}

  /* ====== Page-specific shells ====== */
  .choreo-shell{display:grid;grid-template-rows:1fr 240px;flex:1;overflow:hidden}
  .choreo-top{display:grid;grid-template-columns:280px 1fr 320px;overflow:hidden}

  .anim-shell{display:grid;grid-template-rows:1fr 240px;flex:1;overflow:hidden}
  .anim-top{display:grid;grid-template-columns:240px 1fr 280px;overflow:hidden}

  .lighting-shell{display:grid;grid-template-columns:1fr 320px;flex:1;overflow:hidden}

  .export-shell{display:grid;grid-template-columns:320px 1fr;flex:1;overflow:hidden}
  .export-summary{padding:24px;overflow:auto;background:var(--bg-1);border-right:1px solid var(--bg-0)}
  .export-options{padding:24px;overflow:auto}
  .format-card{background:var(--bg-2);border:1px solid var(--line);border-radius:6px;padding:16px;margin-bottom:10px;cursor:pointer;transition:.15s;display:grid;grid-template-columns:auto 1fr auto;gap:14px;align-items:center}
  .format-card:hover{border-color:var(--accent)}
  .format-card.selected{border-color:var(--accent);background:rgba(255,140,26,.05)}
  .format-card .icon-box{width:44px;height:44px;border-radius:6px;background:linear-gradient(135deg,var(--accent),#e87410);display:flex;align-items:center;justify-content:center;color:white;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:11px;letter-spacing:.5px}
  .format-card.cyan .icon-box{background:linear-gradient(135deg,var(--cyan),#0097a7)}
  .format-card.purple .icon-box{background:linear-gradient(135deg,var(--purple),#6a1b9a)}
  .format-card.red .icon-box{background:linear-gradient(135deg,var(--danger),#c62828)}
  .format-card .name{font-size:13px;font-weight:500;color:var(--text-0)}
  .format-card .desc{color:var(--text-2);font-size:10.5px;margin-top:2px}
  .drone-spec-table{width:100%;font-size:11px}
  .drone-spec-table tr{border-bottom:1px solid var(--bg-0)}
  .drone-spec-table td{padding:6px 0}
  .drone-spec-table td:first-child{color:var(--text-2);width:40%}
  .drone-spec-table td:last-child{color:var(--text-0);font-variant-numeric:tabular-nums;text-align:right}

  /* CapCut timeline (used in Animation + Choreography) */
  .timeline-shell{background:var(--bg-1);border-top:1px solid var(--bg-0);display:grid;grid-template-rows:38px 22px 1fr;overflow:hidden}
  .tl-toolbar{display:flex;align-items:center;gap:8px;padding:0 12px;background:var(--bg-2);border-bottom:1px solid var(--bg-0)}
  .tl-transport{display:flex;gap:2px}
  .tl-tbtn{width:26px;height:22px;background:var(--bg-3);border:1px solid var(--line);color:var(--text-1);border-radius:3px;cursor:pointer;font-size:10px;display:flex;align-items:center;justify-content:center}
  .tl-tbtn:hover{background:var(--bg-4);color:var(--text-0)}
  .tl-tbtn.play{width:32px;background:var(--accent);border-color:var(--accent);color:white}
  .tl-tbtn.play:hover{filter:brightness(1.1)}
  .tl-time{font-variant-numeric:tabular-nums;color:var(--text-0);font-size:12px;background:var(--bg-1);padding:3px 10px;border-radius:3px;border:1px solid var(--line);min-width:110px;text-align:center}
  .tl-time .total{color:var(--text-3)}
  .tl-spacer{flex:1}
  .tl-zoom{display:flex;align-items:center;gap:6px;color:var(--text-2);font-size:10.5px}
  .tl-zoom input[type=range]{width:80px}
  .tl-ruler{background:var(--bg-1);position:relative;border-bottom:1px solid var(--bg-0);overflow:hidden;cursor:pointer}
  .tl-ruler-inner{position:absolute;inset:0}
  .tl-tick{position:absolute;top:0;bottom:0}
  .tl-tick.major{border-left:1px solid var(--line)}
  .tl-tick.minor{border-left:1px solid #1a1f28}
  .tl-tick-label{position:absolute;bottom:3px;transform:translateX(-50%);padding:0 3px;color:var(--text-3);font-size:9px;font-variant-numeric:tabular-nums}
  .tl-tracks{overflow-y:auto;overflow-x:hidden;background:var(--bg-1);position:relative}
  .tl-track{height:38px;display:grid;grid-template-columns:140px 1fr;border-bottom:1px solid #14171d;position:relative}
  .tl-track-head{background:var(--bg-2);border-right:1px solid var(--bg-0);display:flex;align-items:center;padding:0 10px;gap:6px;font-size:10.5px;color:var(--text-1)}
  .tl-track-head .name{flex:1}
  .tl-track-body{position:relative;overflow:hidden}
  .tl-clip{position:absolute;top:4px;bottom:4px;border-radius:4px;cursor:grab;box-shadow:inset 0 1px 0 rgba(255,255,255,.15),0 1px 2px rgba(0,0,0,.3);overflow:hidden;transition:filter .1s}
  .tl-clip:hover{filter:brightness(1.1)}
  .tl-clip.selected{box-shadow:0 0 0 2px var(--select),inset 0 1px 0 rgba(255,255,255,.2)}
  .tl-clip-thumb{position:absolute;left:4px;top:3px;width:26px;height:calc(100% - 6px);background-size:cover;background-position:center;border-radius:2px}
  .tl-clip-label{position:absolute;left:36px;top:50%;transform:translateY(-50%);color:white;font-size:10.5px;font-weight:500;text-shadow:0 1px 2px rgba(0,0,0,.5);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;right:6px}
  .tl-clip-handle{position:absolute;top:0;bottom:0;width:6px;cursor:ew-resize;background:rgba(255,255,255,.1)}
  .tl-clip-handle.left{left:0;border-radius:4px 0 0 4px}
  .tl-clip-handle.right{right:0;border-radius:0 4px 4px 0}
  .tl-clip-handle:hover{background:rgba(255,255,255,.3)}
  .tl-playhead{position:absolute;top:0;bottom:0;width:2px;background:var(--accent);pointer-events:none;z-index:20;box-shadow:0 0 8px var(--accent)}
  .tl-playhead::before{content:'';position:absolute;top:-22px;left:-6px;width:14px;height:18px;background:var(--accent);clip-path:polygon(0 0,100% 0,100% 60%,50% 100%,0 60%)}

  /* single drone editor */
  .led-cell{display:grid;grid-template-columns:24px 1fr auto;gap:10px;align-items:center;padding:8px 0;border-bottom:1px solid var(--bg-0)}
  .led-cell:last-child{border-bottom:none}
  .led-cell .swatch{width:22px;height:22px;border-radius:50%;border:1px solid var(--line);cursor:pointer;position:relative;box-shadow:0 0 8px currentColor}
