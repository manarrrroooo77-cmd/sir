// ============== CAGED DRONE PROCEDURAL ==============
function makeCagedDrone(opts = {}) {
  const radius = opts.radius || 1;
  const subdiv = opts.subdiv ?? 2;
  const tint = opts.tint || '#7e2a8c';
  const leds = opts.leds || ['#f5d0e0', '#cdfacd', '#fff58a', '#ffffff'];

  const group = new THREE.Group();
  const ico = new THREE.IcosahedronGeometry(radius, subdiv);
  const posAttr = ico.attributes.position;
  const verts = [];
  const seen = new Map();
  for (let i = 0; i < posAttr.count; i++) {
    const x = posAttr.getX(i), y = posAttr.getY(i), z = posAttr.getZ(i);
    const k = `${x.toFixed(3)}|${y.toFixed(3)}|${z.toFixed(3)}`;
    if (!seen.has(k)) { seen.set(k, verts.length); verts.push(new THREE.Vector3(x, y, z)); }
  }
  const edges = new Set();
  function findVert(x, y, z) { return seen.get(`${x.toFixed(3)}|${y.toFixed(3)}|${z.toFixed(3)}`); }
  for (let i = 0; i < posAttr.count; i += 3) {
    const a = findVert(posAttr.getX(i), posAttr.getY(i), posAttr.getZ(i));
    const b = findVert(posAttr.getX(i+1), posAttr.getY(i+1), posAttr.getZ(i+1));
    const c = findVert(posAttr.getX(i+2), posAttr.getY(i+2), posAttr.getZ(i+2));
    [[a,b],[b,c],[c,a]].forEach(([x,y]) => edges.add(x < y ? `${x}-${y}` : `${y}-${x}`));
  }
  ico.dispose();

  const cageColor = new THREE.Color(tint);
  const cageDark = cageColor.clone().multiplyScalar(0.45);
  const cageMat = new THREE.MeshStandardMaterial({ color: cageDark, transparent: true, opacity: 0.85, roughness: 0.5, metalness: 0.4 });

  const strutGeo = new THREE.CylinderGeometry(0.012, 0.012, 1, 6, 1);
  strutGeo.translate(0, 0.5, 0);
  const strutInst = new THREE.InstancedMesh(strutGeo, cageMat, edges.size);
  let ei = 0;
  const dummy = new THREE.Object3D();
  edges.forEach(k => {
    const [a, b] = k.split('-').map(Number);
    const va = verts[a], vb = verts[b];
    const dir = vb.clone().sub(va);
    const len = dir.length();
    dummy.position.copy(va);
    dummy.scale.set(1, len, 1);
    const up = new THREE.Vector3(0, 1, 0);
    const dn = dir.clone().normalize();
    const axis = up.clone().cross(dn).normalize();
    const angle = Math.acos(Math.max(-1, Math.min(1, up.dot(dn))));
    if (axis.lengthSq() > 1e-6) dummy.quaternion.setFromAxisAngle(axis, angle);
    else { dummy.quaternion.identity(); if (dn.y < 0) dummy.quaternion.setFromAxisAngle(new THREE.Vector3(1,0,0), Math.PI); }
    dummy.updateMatrix();
    strutInst.setMatrixAt(ei++, dummy.matrix);
  });
  strutInst.instanceMatrix.needsUpdate = true;
  group.add(strutInst);

  // Ring assignment: 4 rings by Y
  const ys = verts.map(v => v.y).sort((a, b) => a - b);
  const rb = [ys[Math.floor(ys.length*0.25)], ys[Math.floor(ys.length*0.5)], ys[Math.floor(ys.length*0.75)]];
  function ringFor(y) { return y < rb[0] ? 0 : y < rb[1] ? 1 : y < rb[2] ? 2 : 3; }

  const ledNodes = [];
  const nodeGeo = new THREE.SphereGeometry(0.07, 14, 10);
  verts.forEach((v) => {
    const ring = ringFor(v.y);
    const ledColor = new THREE.Color(leds[ring]);
    const m = new THREE.MeshStandardMaterial({ color: ledColor.clone().multiplyScalar(0.4), emissive: ledColor, emissiveIntensity: 1.2, roughness: 0.3, metalness: 0.1 });
    const node = new THREE.Mesh(nodeGeo, m);
    node.position.copy(v);
    node.userData.led = { ring };
    group.add(node);

    const glow = new THREE.Sprite(new THREE.SpriteMaterial({ map: glowTexture, color: ledColor, transparent: true, blending: THREE.AdditiveBlending, depthWrite: false, opacity: 0.6 }));
    glow.scale.set(0.28, 0.28, 1);
    glow.position.copy(v);
    group.add(glow);
    node.userData.glow = glow;
    ledNodes.push(node);
  });

  // Inner body
  const body = new THREE.Group();
  const elec = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.16, 0.4), new THREE.MeshStandardMaterial({ color: 0xc8d0e0, roughness: 0.6, metalness: 0.2 }));
  body.add(elec);
  const battery = new THREE.Mesh(new THREE.BoxGeometry(0.45, 0.04, 0.35), new THREE.MeshStandardMaterial({ color: 0xb0b8c0, roughness: 0.4, metalness: 0.3 }));
  battery.position.y = 0.11; body.add(battery);
  const arm = new THREE.Mesh(new THREE.CylinderGeometry(0.04, 0.04, radius * 1.9, 12), new THREE.MeshStandardMaterial({ color: 0x2a2a2e, roughness: 0.7, metalness: 0.6 }));
  arm.rotation.z = Math.PI / 2; body.add(arm);
  const motorMat = new THREE.MeshStandardMaterial({ color: 0x5a5a60, roughness: 0.3, metalness: 0.85 });
  for (const dx of [-0.32, 0.32]) {
    const m = new THREE.Mesh(new THREE.CylinderGeometry(0.06, 0.06, 0.1, 12), motorMat);
    m.position.set(dx, 0, 0); body.add(m);
  }
  const propMat = new THREE.MeshStandardMaterial({ color: 0xeeeeee, transparent: true, opacity: 0.55, roughness: 0.4, side: THREE.DoubleSide });
  const props = new THREE.Group();
  for (const dx of [-0.32, 0.32]) {
    const p = new THREE.Mesh(new THREE.BoxGeometry(0.7, 0.005, 0.04), propMat);
    p.position.set(dx, 0.07, 0); props.add(p);
  }
  body.add(props);
  body.userData.props = props;
  group.add(body);

  group.userData = { ledNodes, body, cageMat, leds: leds.slice() };
  return group;
}

