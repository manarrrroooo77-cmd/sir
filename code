function getTargetPoints(clip, n) {
  if (clip.kind === 'custom' && clip.customDrones) return clip.customDrones.slice(0, n).map(d => [d.x, d.y, d.z]);
  return (formations[clip.formation] || formations.circle)(n);
}
function getTargetColors(clip, n) {
  if (clip.kind === 'custom' && clip.customDrones) return clip.customDrones.slice(0, n).map(d => d.color);
  const palette = FORMATION_PALETTES[clip.formation] || ['#ff8c1a'];
  const out = [];
  for (let i = 0; i < n; i++) out.push(pickPalette(palette, i / Math.max(1, n - 1)));
  return out;
}
function matchPoints(prev, next) {
  const n = prev.length; const used = new Array(next.length).fill(false); const order = new Array(n);
  for (let i = 0; i < n; i++) {
    let best = -1, bd = Infinity;
    for (let j = 0; j < next.length; j++) {
      if (used[j]) continue;
      const dx = prev[i][0]-next[j][0], dy = prev[i][1]-next[j][1], dz = prev[i][2]-next[j][2];
      const d = dx*dx+dy*dy+dz*dz;
      if (d < bd) { bd = d; best = j; }
    }
    if (best >= 0) { order[i] = best; used[best] = true; } else order[i] = i;
  }
  return order;
}
