      }
    });
    document.getElementById('ddet-close').addEventListener('click', () => {
      editPanel.classList.remove('visible'); selectedDroneIdx = null; pickMarker.style.display = 'none';
    });

    function resize() {
      const w = canvas.parentElement.clientWidth, h = canvas.parentElement.clientHeight;
      renderer.setSize(w, h, false); camera.aspect = w/h; camera.updateProjectionMatrix();
    }
    resize();
    const onResize = () => resize();
    window.addEventListener('resize', onResize);

    // formation library panel
    const lib = document.getElementById('dd-formation-library');
    if (lib) {
      const formationsList = ['aladdinLamp','genie','soccerBall','soccerPlayer','goalAndBall','worldCupTrophy','witchHat','airplane','magicStar','magicWand','heart','star','sphere','helix','wave'];
      lib.innerHTML = formationsList.map(f => `
        <div class="det-item" data-form="${f}" style="cursor:pointer;">
          <div class="dot" style="color:${door.accent}; background:${door.accent};"></div>
          <div><div class="name" style="text-transform:capitalize;">${f.replace(/([A-Z])/g, ' $1').trim()}</div><div class="meta">tap to apply</div></div>
          <div class="conf">▶</div>
        </div>
      `).join('');
      lib.querySelectorAll('[data-form]').forEach(el => {
        el.addEventListener('click', () => {
          triggerSwarmMorph({ droneFormation: el.dataset.form, color: 'orange' });
          showToast(`Manual formation: ${el.dataset.form}`);
        });
      });
    }

    let raf = 0; let lastT = performance.now();
    let fpsTimer = 0, fpsCount = 0;
    function loop() {
      const now = performance.now(); const dt = now - lastT; lastT = now;
      tick(dt); checkDetections(); updateSwarm(now);
      orbit.state.azim += dt * 0.00006; orbit.update();
      fpsTimer += dt; fpsCount++;
      if (fpsTimer > 500) {
        const f = document.getElementById('dd-fps');
        if (f) f.textContent = Math.round(1000 / (fpsTimer / fpsCount));
        fpsTimer = 0; fpsCount = 0;
      }
      renderer.render(scene, camera);
      raf = requestAnimationFrame(loop);
    }
    raf = requestAnimationFrame(loop);
    setPlaying(true);

    detailDispose = () => {
      cancelAnimationFrame(raf);
      window.removeEventListener('resize', onResize);
      orbit.dispose(); renderer.dispose();
      if (videoEl) { try { videoEl.pause(); } catch(e){} videoEl.remove(); }
      if (ytIframe) ytIframe.remove();
      if (pickMarker) pickMarker.remove();
      if (editPanel) editPanel.remove();
    };
  }

  sceneRegistry.doors = {
    dispose: () => { if (detailDispose) detailDispose(); detailDispose = null; }
  };
}



// ============== LIBRARY THUMB GENERATOR ==============
function makeLibraryThumbSVG(item) {
  // Render a small preview of the formation from a top-down + 45° camera projection
  const drones = item.formationFn();
  const W = 240, H = 180;
  // bounding box
  let xs = drones.map(d => d.x), ys = drones.map(d => d.y), zs = drones.map(d => d.z);
  const xMin = Math.min(...xs), xMax = Math.max(...xs);
  const yMin = Math.min(...ys), yMax = Math.max(...ys);
  const zMin = Math.min(...zs), zMax = Math.max(...zs);
  const cx = (xMin + xMax) / 2;
  const cy = (yMin + yMax) / 2;
  const range = Math.max(xMax - xMin, yMax - yMin, zMax - zMin) * 1.15 + 0.5;
  // Project each drone to 2D
  const pts = drones.map(d => {
    const dx = (d.x - cx) / range;
    const dy = (d.y - cy) / range;
    return { sx: W/2 + dx * (W * 0.42), sy: H/2 - dy * (H * 0.42), c: d.color };
  });
  return `<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg">
    <defs><filter id="lib-glow"><feGaussianBlur stdDeviation="1.5"/></filter></defs>
    <rect width="${W}" height="${H}" fill="#050709"/>
    <g opacity=".25" stroke="#1a2030" stroke-width=".5">
      ${Array.from({length:8},(_,i)=>`<line x1="0" y1="${i*H/8}" x2="${W}" y2="${i*H/8}"/>`).join('')}
      ${Array.from({length:10},(_,i)=>`<line x1="${i*W/10}" y1="0" x2="${i*W/10}" y2="${H}"/>`).join('')}
    </g>
    <g filter="url(#lib-glow)" opacity=".7">${pts.map(p => `<circle cx="${p.sx.toFixed(1)}" cy="${p.sy.toFixed(1)}" r="2.4" fill="${p.c}"/>`).join('')}</g>
    <g>${pts.map(p => `<circle cx="${p.sx.toFixed(1)}" cy="${p.sy.toFixed(1)}" r="1" fill="${p.c}"/>`).join('')}</g>
    <circle cx="${W*0.85}" cy="${H*0.15}" r="1.3" fill="white" opacity=".8"/>
    <circle cx="${W*0.92}" cy="${H*0.22}" r=".8" fill="white" opacity=".5"/>
    <circle cx="${W*0.12}" cy="${H*0.18}" r=".9" fill="white" opacity=".6"/>
  </svg>`;
}

