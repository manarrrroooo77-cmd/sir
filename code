      activeCat = chip.dataset.cat;
      filters.querySelectorAll('.lib-filter-chip').forEach(x => x.classList.toggle('active', x.dataset.cat === activeCat));
      render();
    });
  });

  function render() {
    const items = activeCat === 'All' ? LIBRARY : LIBRARY.filter(x => x.category === activeCat);
    grid.innerHTML = items.map(item => `
      <div class="lib-card" data-id="${item.id}">
