  if (!tpl) return console.error('no template for', page);
  stage.appendChild(tpl.content.cloneNode(true));
  stage.querySelector('.page').classList.add('active');

  stage.querySelectorAll('[data-go]').forEach(el => {
    el.addEventListener('click', (e) => { e.stopPropagation(); navigateTo(el.dataset.go); });
  });

  app.currentPage = page;
  if (page === 'layout') initLayout();
  else if (page === 'modeling') initModeling();
  else if (page === 'animation') initAnimation();
  else if (page === 'lighting') initLighting();
  else if (page === 'choreography') initChoreography();
  else if (page === 'drone-edit') initDroneEdit(opts.droneId);
