// ============== PAGE: LAYOUT ==============
function initLayout() { sceneRegistry.layout = { dispose: () => {} }; }

// ============== PAGE: MODELING (DOTS + AI) ==============
function initModeling() {
  const canvas = document.getElementById('md-canvas');
  if (!canvas) return;
  const renderer = makeRendererForCanvas(canvas);
  const scene = new THREE.Scene();
  scene.fog = new THREE.FogExp2(0x040608, 0.012);
  const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 500);
  makeNightSky(scene); makeGroundGrid(scene, 60);
  scene.add(new THREE.AmbientLight(0x4a5a7a, 0.4));

  const orbit = attachOrbitControls(canvas, camera, { dist: 22, target: new THREE.Vector3(0,2,0), elev: 0.3, maxDist: 60 });

  // Build glowing dot sprites + tiny core spheres
  const swarmGroup = new THREE.Group(); scene.add(swarmGroup);
  let dotMeshes = []; // for picking
  let glows = [];
  function rebuildSwarmVisuals() {
    dotMeshes.forEach(m => { swarmGroup.remove(m); m.geometry.dispose(); m.material.dispose(); });
    glows.forEach(g => { swarmGroup.remove(g); g.material.dispose(); });
    dotMeshes = []; glows = [];
    app.swarm.drones.forEach(d => {
      const c = new THREE.Color(d.color);
      const geo = new THREE.SphereGeometry(0.08, 10, 8);
      const mat = new THREE.MeshBasicMaterial({ color: c });
      const mesh = new THREE.Mesh(geo, mat);
      mesh.position.set(d.x, d.y, d.z);
      mesh.userData.droneId = d.id;
      swarmGroup.add(mesh);
      dotMeshes.push(mesh);

      const glowMat = new THREE.SpriteMaterial({ map: glowTexture, color: c, transparent: true, blending: THREE.AdditiveBlending, depthWrite: false });
      const glow = new THREE.Sprite(glowMat);
      glow.scale.set(0.6, 0.6, 1);
      glow.position.copy(mesh.position);
      swarmGroup.add(glow);
      glows.push(glow);
    });
    applyVisualSettings();
    refreshOutliner();
    document.getElementById('md-info-count').textContent = app.swarm.drones.length;
    document.getElementById('md-info-formation').textContent = app.swarm.formation;
  }
  function applyVisualSettings() {
    const s = app.md.size / 100;
    glows.forEach((g, i) => {
      g.scale.set(0.6 * s, 0.6 * s, 1);
      g.material.opacity = app.md.glow / 100;
    });
    // selection highlights
    app.swarm.drones.forEach((d, i) => {
      const isSel = app.swarm.selected.has(d.id);
      const c = new THREE.Color(d.color);
      const dispC = isSel ? new THREE.Color(0xffeb3b) : c;
      dotMeshes[i].material.color = dispC;
      glows[i].material.color = dispC;
      if (isSel) glows[i].scale.set(0.9 * s, 0.9 * s, 1);
    });
    document.getElementById('md-info-selected').textContent = app.swarm.selected.size;
  }
  rebuildSwarmVisuals();

  // ====== OUTLINER ======
  function refreshOutliner() {
    const list = document.getElementById('md-struct-list');
    if (!list) return;
    const n = app.swarm.drones.length;
    const max = Math.min(n, 14);
    let html = '';
    for (let i = 0; i < max; i++) {
      const d = app.swarm.drones[i];
      const isSel = app.swarm.selected.has(d.id);
      html += `<div class="struct-row ${isSel ? 'active' : ''}" data-droneid="${d.id}">
        <div class="dot" style="color:${d.color}; background:${d.color};"></div>
        <span>Drone.${String(d.id).padStart(3,'0')}</span>
      </div>`;
    }
    if (n > max) html += `<div class="struct-row" style="color:var(--text-3); cursor:default;"><span style="margin-left:18px;">+${n - max} more…</span></div>`;
    list.innerHTML = html;
    list.querySelectorAll('[data-droneid]').forEach(r => {
      r.addEventListener('click', (e) => {
        const id = parseInt(r.dataset.droneid);
        if (!e.ctrlKey && !e.metaKey) app.swarm.selected.clear();
        app.swarm.selected.add(id);
        applyVisualSettings();
        refreshOutliner();
        updatePropPanel();
      });
    });
  }

  // ====== TOOL HANDLERS ======
  let currentTool = 'select';
  document.querySelectorAll('#md-tools .tool-btn').forEach(b => {
    b.addEventListener('click', () => {
      document.querySelectorAll('#md-tools .tool-btn').forEach(x => x.classList.remove('active'));
      b.classList.add('active');
      currentTool = b.dataset.tool;
    });
  });

  // ====== PICKING / DRAG ======
  let dragging = false, dragId = null, dragStart = null;
  function pick(clientX, clientY) {
    const rect = canvas.getBoundingClientRect();
    let best = null, bestDist = Infinity;
    for (const d of app.swarm.drones) {
      const v = new THREE.Vector3(d.x, d.y, d.z).project(camera);
      const sx = (v.x + 1) / 2 * rect.width;
      const sy = (-v.y + 1) / 2 * rect.height;
      const dx = sx - (clientX - rect.left), dy = sy - (clientY - rect.top);
      const dist = Math.sqrt(dx*dx + dy*dy);
      if (dist < 24 && dist < bestDist) { bestDist = dist; best = d; }
    }
    return best;
  }
  canvas.addEventListener('mousedown', (e) => {
    if (e.button !== 0 || e.shiftKey) return;
    if (currentTool === 'orbit') return;
    const d = pick(e.clientX, e.clientY);
    if (d) {
      if (currentTool === 'paint') {
        d.color = document.getElementById('md-color').value;
        rebuildSwarmVisuals();
        return;
      }
      if (currentTool === 'select') {
        if (!e.ctrlKey && !e.metaKey) app.swarm.selected.clear();
        app.swarm.selected.add(d.id);
        applyVisualSettings(); refreshOutliner(); updatePropPanel();
      }
      if (currentTool === 'move' && app.swarm.selected.has(d.id)) {
        dragging = true; dragId = d.id;
        dragStart = { x: e.clientX, y: e.clientY, pos: new THREE.Vector3(d.x, d.y, d.z) };
        document.getElementById('md-drag-info').style.display = 'block';
      }
    } else if (currentTool === 'select' && !e.ctrlKey && !e.metaKey) {
      app.swarm.selected.clear();
      applyVisualSettings(); refreshOutliner(); updatePropPanel();
    }
  });
  canvas.addEventListener('mousemove', (e) => {
    if (!dragging || dragId === null) return;
    const drone = app.swarm.drones.find(d => d.id === dragId);
    if (!drone) return;
    const dx = (e.clientX - dragStart.x) * orbit.state.dist * 0.001;
    const dy = -(e.clientY - dragStart.y) * orbit.state.dist * 0.001;
    const right = new THREE.Vector3(); const up = new THREE.Vector3();
    camera.matrix.extractBasis(right, up, new THREE.Vector3());
    const np = dragStart.pos.clone().addScaledVector(right, dx).addScaledVector(up, dy);
    drone.x = np.x; drone.y = np.y; drone.z = np.z;
    const i = app.swarm.drones.indexOf(drone);
    dotMeshes[i].position.copy(np); glows[i].position.copy(np);
    updatePropPanel();
    const di = document.getElementById('md-drag-info');
    di.textContent = `X: ${np.x.toFixed(2)} Y: ${np.y.toFixed(2)} Z: ${np.z.toFixed(2)}`;
    di.style.left = (e.clientX + 12) + 'px'; di.style.top = (e.clientY + 12) + 'px';
  });
  canvas.addEventListener('mouseup', () => {
    if (dragging) { dragging = false; dragId = null; document.getElementById('md-drag-info').style.display = 'none'; }
  });

  // ====== PROPERTIES PANEL ======
  function updatePropPanel() {
    const lbl = document.getElementById('md-prop-id');
    if (app.swarm.selected.size === 0) {
      lbl.textContent = 'none selected'; lbl.style.color = 'var(--text-2)';
      document.getElementById('md-px').value = 0;
      document.getElementById('md-py').value = 0;
      document.getElementById('md-pz').value = 0;
    } else if (app.swarm.selected.size === 1) {
      const id = [...app.swarm.selected][0];
      const d = app.swarm.drones.find(x => x.id === id);
      lbl.innerHTML = `<span style="color:var(--select);">#${String(id).padStart(3,'0')}</span>`;
      lbl.style.color = 'var(--text-0)';
      document.getElementById('md-px').value = d.x.toFixed(2);
      document.getElementById('md-py').value = d.y.toFixed(2);
      document.getElementById('md-pz').value = d.z.toFixed(2);
      document.getElementById('md-color').value = d.color.startsWith('#') ? d.color : '#4dd0e1';
    } else {
      lbl.innerHTML = `<span style="color:var(--select);">${app.swarm.selected.size}</span> drones`;
      lbl.style.color = 'var(--text-0)';
    }
  }
  ['md-px','md-py','md-pz'].forEach((id, axis) => {
    document.getElementById(id).addEventListener('input', (e) => {
      if (app.swarm.selected.size !== 1) return;
      const did = [...app.swarm.selected][0];
      const d = app.swarm.drones.find(x => x.id === did);
      const v = parseFloat(e.target.value) || 0;
      if (axis === 0) d.x = v; if (axis === 1) d.y = v; if (axis === 2) d.z = v;
      const i = app.swarm.drones.indexOf(d);
      dotMeshes[i].position.set(d.x, d.y, d.z); glows[i].position.copy(dotMeshes[i].position);
    });
  });
  document.getElementById('md-color').addEventListener('input', (e) => {
    const c = e.target.value;
    app.swarm.selected.forEach(id => {
      const d = app.swarm.drones.find(x => x.id === id);
      if (d) d.color = c;
    });
    rebuildSwarmVisuals();
  });
  document.querySelectorAll('.color-preset').forEach(p => p.addEventListener('click', () => {
    const c = p.dataset.color;
    document.getElementById('md-color').value = c;
    app.swarm.selected.forEach(id => {
      const d = app.swarm.drones.find(x => x.id === id);
      if (d) d.color = c;
    });
    rebuildSwarmVisuals();
  }));

  // Populate the Library section in this Modeling panel
  const mdLib = document.getElementById('md-library-list');
  if (mdLib) {
    mdLib.innerHTML = LIBRARY.map(item => `
      <div class="md-lib-row" data-id="${item.id}">
        <div class="swatch" style="background:${item.accent};"></div>
        <div>
          <div class="nm">${item.name}</div>
          <div class="ct">${item.category}</div>
        </div>
        <div class="arrow">→</div>
      </div>
    `).join('');
    mdLib.querySelectorAll('.md-lib-row').forEach(row => {
      row.addEventListener('click', () => applyLibraryItem(row.dataset.id));
    });
  }

  // Sliders
  document.querySelectorAll('[data-md-slider]').forEach(row => bindSlider(row, 'md-slider', (name, v) => {
    if (name === 'count') {
      buildSwarmFromFormation(app.swarm.formation, v);
      app.swarm.selected.clear();
      rebuildSwarmVisuals();
    } else {
      app.md[name] = v;
      applyVisualSettings();
    }
  }));

  // Quick actions
  document.getElementById('md-select-all').addEventListener('click', () => {
    app.swarm.drones.forEach(d => app.swarm.selected.add(d.id));
    applyVisualSettings(); refreshOutliner(); updatePropPanel();
  });
  document.getElementById('md-deselect').addEventListener('click', () => {
    app.swarm.selected.clear();
    applyVisualSettings(); refreshOutliner(); updatePropPanel();
  });
  document.getElementById('md-fit-all').addEventListener('click', () => {
    orbit.state.target.set(0, 2, 0); orbit.state.dist = 22; orbit.state.azim = 0; orbit.state.elev = 0.3; orbit.update();
  });
  document.getElementById('md-clear').addEventListener('click', () => {
    buildSwarmFromFormation('grid', 20);
    app.swarm.selected.clear();
    rebuildSwarmVisuals();
    showToast('Swarm reset to grid');
  });

  // AI tabs
  document.querySelectorAll('.ai-tab').forEach(t => {
    t.addEventListener('click', () => {
      document.querySelectorAll('.ai-tab').forEach(x => x.classList.remove('active'));
      t.classList.add('active');
      ['text','image','preset'].forEach(k => { document.getElementById('aiPanel-' + k).style.display = k === t.dataset.aitab ? 'block' : 'none'; });
    });
  });
  document.querySelectorAll('.ai-chip').forEach(c => c.addEventListener('click', () => { document.getElementById('aiTextInput').value = c.dataset.prompt; }));
  document.querySelectorAll('[data-preset]').forEach(b => {
    b.addEventListener('click', () => {
      buildSwarmFromFormation(b.dataset.preset, app.swarm.count);
      app.swarm.selected.clear();
      rebuildSwarmVisuals();
      showToast(`Loaded ${b.dataset.preset} formation`);
    });
  });

  // Image upload
  let uploadedImage = null;
  const uploadZone = document.getElementById('uploadZone');
  const fileInput = document.getElementById('fileInput');
  uploadZone.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', (e) => {
    const f = e.target.files[0]; if (!f) return;
    const reader = new FileReader();
    reader.onload = ev => {
      uploadedImage = ev.target.result;
      uploadZone.innerHTML = `<img src="${uploadedImage}" alt=""><div class="label" style="margin-top:6px;">${f.name}</div><div class="sub">click to replace</div>`;
      document.getElementById('generateImage').disabled = false;
    };
    reader.readAsDataURL(f);
  });

  function setStatus(text, kind = '') {
    const el = document.getElementById('aiStatus');
    el.className = 'ai-status ' + kind;
    el.innerHTML = kind === 'thinking' ? `<div class="spinner"></div><span>${text}</span>` : `<span>${text}</span>`;
  }

  async function callClaudeForFormation(messages) {
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ model: "claude-sonnet-4-20250514", max_tokens: 4000, messages })
    });
    if (!response.ok) throw new Error('API ' + response.status);
    const data = await response.json();
    const text = data.content.filter(b => b.type === 'text').map(b => b.text).join('\n');
    const cleaned = text.replace(/```json|```/g, '').trim();
    const start = cleaned.indexOf('{'); const end = cleaned.lastIndexOf('}');
    if (start === -1 || end === -1) throw new Error('No JSON found');
    return JSON.parse(cleaned.slice(start, end + 1));
  }
  const FORMATION_PROMPT = (count) => `You design drone-show light formations. Output ONLY a JSON object:
{"name": "short name", "drones": [{"x": <num>, "y": <num>, "z": <num>, "color": "#RRGGBB"}]}
Rules:
- EXACTLY ${count} drones.
- Coordinates: x ∈ [-7, 7], y ∈ [-1, 8], z ∈ [-4, 4].
- 2D shapes (heart, star, letters) sit in X-Y plane (z near 0).
- Words: each character as a dot pattern with proper spacing.
- Even distribution; no clumping.
- Vibrant LED colors.
- NO text outside the JSON.`;

  document.getElementById('generateText').addEventListener('click', async () => {
    const prompt = document.getElementById('aiTextInput').value.trim();
    if (!prompt) { setStatus('Type a description first', 'error'); return; }
    setStatus(`Designing ${app.swarm.count}-drone formation…`, 'thinking');
    try {
      const result = await callClaudeForFormation([{ role: 'user', content: FORMATION_PROMPT(app.swarm.count) + '\n\nDescription: ' + prompt }]);
      const customDrones = result.drones.map(d => ({
        x: Math.max(-7, Math.min(7, +d.x || 0)),
        y: Math.max(-1, Math.min(8, +d.y || 0)),
        z: Math.max(-4, Math.min(4, +d.z || 0)),
        color: d.color || '#4dd0e1'
      }));
      buildSwarmFromFormation('ai', app.swarm.count, customDrones);
      app.swarm.selected.clear();
      rebuildSwarmVisuals();
      setStatus(`✓ "${result.name || prompt}" generated`, 'success');
      showToast(`Formation: ${result.name || prompt}`);
    } catch (err) { setStatus('Failed: ' + err.message, 'error'); }
  });
  document.getElementById('generateImage').addEventListener('click', async () => {
    if (!uploadedImage) return;
    setStatus(`Scanning image with vision model…`, 'thinking');
    // Step 1: try local recognition for known logos (Riyadh Season etc.)
    try {
      const recognized = await recognizeImage(uploadedImage);
      if (recognized) {
        const customDrones = recognized.ref.formationFn();
        buildSwarmFromFormation('logo-' + recognized.key, customDrones.length, customDrones);
        app.swarm.selected.clear();
        rebuildSwarmVisuals();
        setStatus(`✓ Recognized: ${recognized.ref.name} — generated ${customDrones.length}-drone formation`, 'success');
        showToast(`Logo recognized: ${recognized.ref.name}`);
        return;
      }
    } catch (err) { console.warn('local recognition failed', err); }
    // Step 2: fall through to Claude vision
    setStatus(`Designing formation with AI vision…`, 'thinking');
    try {
      const m = uploadedImage.match(/^data:(image\/[^;]+);base64,(.+)$/);
      const result = await callClaudeForFormation([{ role: 'user', content: [
        { type: 'image', source: { type: 'base64', media_type: m[1], data: m[2] } },
        { type: 'text', text: FORMATION_PROMPT(app.swarm.count) + '\n\nAnalyze the image, identify the main subject, and design a drone formation that captures its silhouette in 2D.' }
      ]}]);
      const customDrones = result.drones.map(d => ({
        x: Math.max(-7, Math.min(7, +d.x || 0)),
        y: Math.max(-1, Math.min(8, +d.y || 0)),
        z: Math.max(-4, Math.min(4, +d.z || 0)),
        color: d.color || '#4dd0e1'
      }));
      buildSwarmFromFormation('ai', app.swarm.count, customDrones);
      rebuildSwarmVisuals();
      setStatus(`✓ Image converted`, 'success');
    } catch (err) { setStatus('Failed: ' + err.message, 'error'); }
  });

  // Resize + animate
  function resize() {
    const w = canvas.parentElement.clientWidth, h = canvas.parentElement.clientHeight;
    renderer.setSize(w, h, false);
    camera.aspect = w / h; camera.updateProjectionMatrix();
  }
  resize();
  const onResize = () => resize();
  window.addEventListener('resize', onResize);

  let raf = 0; let lastT = performance.now();
  function loop() {
    const now = performance.now(); const dt = now - lastT; lastT = now;
    if (app.md.spin > 0) swarmGroup.rotation.y += dt * 0.0001 * app.md.spin;
    // Bob
    app.swarm.drones.forEach((d, i) => {
      const b = Math.sin(now * 0.001 + i * 0.3) * 0.02;
      if (dotMeshes[i]) {
        dotMeshes[i].position.y = d.y + b;
        glows[i].position.y = dotMeshes[i].position.y;
      }
    });
    renderer.render(scene, camera);
    raf = requestAnimationFrame(loop);
  }
  raf = requestAnimationFrame(loop);

  sceneRegistry.modeling = {
    dispose: () => {
      cancelAnimationFrame(raf);
      window.removeEventListener('resize', onResize);
      orbit.dispose();
      renderer.dispose();
    }
  };
}

// ============== PAGE: ANIMATION (CapCut-style keyframe editor) ==============
function initAnimation() {
  const canvas = document.getElementById('anim-canvas');
  if (!canvas) return;
  const renderer = makeRendererForCanvas(canvas);
  const scene = new THREE.Scene();
  scene.fog = new THREE.FogExp2(0x040608, 0.012);
  const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 200);
  makeNightSky(scene); makeGroundGrid(scene, 40);
  scene.add(new THREE.AmbientLight(0x4a5a7a, 0.4));

  const orbit = attachOrbitControls(canvas, camera, { dist: 16, target: new THREE.Vector3(0, 2, 0), elev: 0.3 });

  // Show all dots; highlight selected
  const swarmGroup = new THREE.Group(); scene.add(swarmGroup);
  const dotMeshes = []; const glows = [];
  app.swarm.drones.forEach(d => {
    const c = new THREE.Color(d.color);
    const mesh = new THREE.Mesh(new THREE.SphereGeometry(0.08, 10, 8), new THREE.MeshBasicMaterial({ color: c }));
    mesh.position.set(d.x, d.y, d.z);
    mesh.userData.droneId = d.id;
    swarmGroup.add(mesh);
    dotMeshes.push(mesh);
    const glow = new THREE.Sprite(new THREE.SpriteMaterial({ map: glowTexture, color: c, transparent: true, blending: THREE.AdditiveBlending, depthWrite: false, opacity: 0.7 }));
    glow.scale.set(0.6, 0.6, 1); glow.position.copy(mesh.position);
    swarmGroup.add(glow); glows.push(glow);
  });

  // Curve viz for selected drone
  let pathLine = null;
  function drawPathFor(droneId) {
    if (pathLine) { scene.remove(pathLine); pathLine.geometry.dispose(); pathLine.material.dispose(); pathLine = null; }
    const k = app.anim.keys[droneId];
    if (!k || !k.x || k.x.length < 2) return;
    const sorted = k.x.map((kx, i) => ({ t: kx.t, x: kx.v, y: k.y[i].v, z: k.z[i].v })).sort((a,b) => a.t - b.t);
    const pts = sorted.map(p => new THREE.Vector3(p.x, p.y, p.z));
    const curve = new THREE.CatmullRomCurve3(pts);
    const samples = curve.getPoints(80);
    const geo = new THREE.BufferGeometry().setFromPoints(samples);
    pathLine = new THREE.Line(geo, new THREE.LineBasicMaterial({ color: 0xffd54f, transparent: true, opacity: 0.7 }));
    scene.add(pathLine);
    // Add keyframe markers
    sorted.forEach((p, i) => {
      const m = new THREE.Mesh(new THREE.OctahedronGeometry(0.12, 0), new THREE.MeshBasicMaterial({ color: 0xffeb3b }));
      m.position.set(p.x, p.y, p.z);
      pathLine.add(m);
    });
  }

  // Initialize default keys for first 5 drones
  function ensureDefaultKeys(droneId) {
    if (app.anim.keys[droneId]) return;
    const d = app.swarm.drones.find(x => x.id === droneId);
    if (!d) return;
    app.anim.keys[droneId] = {
      x: [{t:0,v:d.x},{t:7.5,v:d.x+2},{t:15,v:d.x},{t:22.5,v:d.x-2},{t:30,v:d.x}],
      y: [{t:0,v:d.y},{t:7.5,v:d.y+2},{t:15,v:d.y+3},{t:22.5,v:d.y+1},{t:30,v:d.y}],
      z: [{t:0,v:d.z},{t:7.5,v:d.z},{t:15,v:d.z+1},{t:22.5,v:d.z-1},{t:30,v:d.z}],
      c: [{t:0,v:d.color},{t:15,v:'#4dd0e1'},{t:30,v:d.color}],
      g: [{t:0,v:0.7},{t:15,v:1.0},{t:30,v:0.7}],
    };
  }
  app.swarm.drones.slice(0, 8).forEach(d => ensureDefaultKeys(d.id));
  ensureDefaultKeys(app.anim.selectedDroneId);
  drawPathFor(app.anim.selectedDroneId);

  // Drone list
  function refreshDroneList() {
    const list = document.getElementById('anim-drone-list');
    list.innerHTML = app.swarm.drones.slice(0, 16).map(d => `
      <div class="struct-row ${d.id === app.anim.selectedDroneId ? 'active' : ''}" data-droneid="${d.id}">
        <div class="dot" style="color:${d.color}; background:${d.color};"></div>
        <span>Drone.${String(d.id).padStart(3,'0')}</span>
      </div>
    `).join('');
    list.querySelectorAll('[data-droneid]').forEach(r => {
      r.addEventListener('click', () => {
        app.anim.selectedDroneId = parseInt(r.dataset.droneid);
        ensureDefaultKeys(app.anim.selectedDroneId);
        drawPathFor(app.anim.selectedDroneId);
        document.getElementById('anim-info-id').textContent = 'Drone #' + String(app.anim.selectedDroneId).padStart(3,'0');
        document.getElementById('anim-kf-title').textContent = 'Keyframe Tracks · Drone #' + String(app.anim.selectedDroneId).padStart(3,'0');
        renderKfTracks();
        refreshDroneList();
      });
    });
  }
  refreshDroneList();

  // Keyframe tracks
  function renderKfTracks() {
    const tracks = document.querySelectorAll('.kf-track');
    const k = app.anim.keys[app.anim.selectedDroneId] || {};
    let totalKeys = 0;
    tracks.forEach(track => {
      const which = track.dataset.kf;
      const arr = k[which] || [];
      totalKeys += arr.length;
      track.innerHTML = '';
      // SVG curve
      if (arr.length > 1 && (which === 'x' || which === 'y' || which === 'z' || which === 'g')) {
        const w = track.clientWidth || 600;
        const h = 24;
        const sorted = arr.slice().sort((a,b) => a.t - b.t);
        const vmin = Math.min(...sorted.map(p => p.v));
        const vmax = Math.max(...sorted.map(p => p.v));
        const vr = vmax - vmin || 1;
        let d = '';
        sorted.forEach((p, i) => {
          const x = (p.t / SHOW_DURATION) * w;
          const y = h - ((p.v - vmin) / vr) * (h - 6) - 3;
          d += (i === 0 ? `M${x.toFixed(1)} ${y.toFixed(1)}` : ` L${x.toFixed(1)} ${y.toFixed(1)}`);
        });
        track.innerHTML = `<svg class="kf-curve" viewBox="0 0 ${w} ${h}" preserveAspectRatio="none"><path d="${d}" fill="none" stroke="#ff8c1a" stroke-width="1.5"/></svg>`;
      }
      arr.forEach((kf, i) => {
        const dot = document.createElement('div');
        dot.className = 'kf-dot';
        dot.style.left = ((kf.t / SHOW_DURATION) * 100) + '%';
        if (kf === app.anim.selectedKey) dot.style.background = 'var(--accent)';
        dot.addEventListener('click', (e) => {
          e.stopPropagation();
          app.anim.selectedKey = kf;
          document.getElementById('anim-key-time').textContent = kf.t.toFixed(2) + 's';
          // Fill panel based on track
          if (which === 'x') document.getElementById('anim-kx').value = kf.v.toFixed(2);
          if (which === 'y') document.getElementById('anim-ky').value = kf.v.toFixed(2);
          if (which === 'z') document.getElementById('anim-kz').value = kf.v.toFixed(2);
          if (which === 'c') document.getElementById('anim-kcolor').value = kf.v;
          renderKfTracks();
        });
        track.appendChild(dot);
      });
      // Click to add a keyframe
      track.addEventListener('click', (e) => {
        if (e.target.classList.contains('kf-dot')) return;
        const rect = track.getBoundingClientRect();
        const t = ((e.clientX - rect.left) / rect.width) * SHOW_DURATION;
        if (!app.anim.keys[app.anim.selectedDroneId]) app.anim.keys[app.anim.selectedDroneId] = {};
        const k2 = app.anim.keys[app.anim.selectedDroneId];
        if (!k2[which]) k2[which] = [];
        // Default value at t
        let val = 0;
        if (which === 'c') val = '#4dd0e1';
        else if (which === 'g') val = 0.7;
        k2[which].push({ t, v: val });
        renderKfTracks();
        drawPathFor(app.anim.selectedDroneId);
      }, { once: false });
    });
    document.getElementById('anim-info-keys').textContent = totalKeys;
  }
  renderKfTracks();

  document.getElementById('anim-add-key').addEventListener('click', () => {
    const k = app.anim.keys[app.anim.selectedDroneId] = app.anim.keys[app.anim.selectedDroneId] || {};
    const t = app.anim.playhead;
    ['x','y','z'].forEach(axis => { (k[axis] = k[axis] || []).push({ t, v: 0 }); });
    (k.c = k.c || []).push({ t, v: '#ffffff' });
    (k.g = k.g || []).push({ t, v: 0.7 });
    renderKfTracks(); drawPathFor(app.anim.selectedDroneId);
    showToast('Keyframe added at ' + t.toFixed(2) + 's');
  });
  document.getElementById('anim-bake').addEventListener('click', () => {
    showToast('Animation baked → Choreography track');
  });
  document.getElementById('anim-key-delete').addEventListener('click', () => {
    if (!app.anim.selectedKey) return;
    const k = app.anim.keys[app.anim.selectedDroneId];
    Object.keys(k).forEach(track => { k[track] = k[track].filter(x => x !== app.anim.selectedKey); });
    app.anim.selectedKey = null;
    renderKfTracks(); drawPathFor(app.anim.selectedDroneId);
  });

  // Resize/animate
  function resize() {
    const w = canvas.parentElement.clientWidth, h = canvas.parentElement.clientHeight;
    renderer.setSize(w, h, false);
    camera.aspect = w / h; camera.updateProjectionMatrix();
  }
  resize();
  const onResize = () => resize();
  window.addEventListener('resize', onResize);

  let raf = 0; let lastT = performance.now();
  function loop() {
    const now = performance.now(); const dt = now - lastT; lastT = now;
    // Animate selected drone along its keys
    const t = ((now * 0.0003) % 1) * SHOW_DURATION;
    const k = app.anim.keys[app.anim.selectedDroneId];
    if (k && k.x && k.x.length > 0) {
      const interp = (arr) => {
        const sorted = arr.slice().sort((a,b)=>a.t-b.t);
        if (t <= sorted[0].t) return sorted[0].v;
        if (t >= sorted[sorted.length-1].t) return sorted[sorted.length-1].v;
        for (let i = 0; i < sorted.length - 1; i++) {
          if (t >= sorted[i].t && t <= sorted[i+1].t) {
            const f = (t - sorted[i].t) / (sorted[i+1].t - sorted[i].t);
            const e = f * f * (3 - 2*f);
            return sorted[i].v + (sorted[i+1].v - sorted[i].v) * e;
          }
        }
        return sorted[0].v;
      };
      const idx = app.swarm.drones.findIndex(d => d.id === app.anim.selectedDroneId);
      if (idx >= 0 && dotMeshes[idx]) {
