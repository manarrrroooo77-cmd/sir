function initLighting() {
  const canvas = document.getElementById('lt-canvas');
  if (!canvas) return;
  const renderer = makeRendererForCanvas(canvas);
  const scene = new THREE.Scene();
  scene.fog = new THREE.FogExp2(0x040608, 0.018);
  const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 200);
  makeNightSky(scene); makeGroundGrid(scene, 40);
  scene.add(new THREE.AmbientLight(0x4a5a7a, 0.3));

  const orbit = attachOrbitControls(canvas, camera, { dist: 16, target: new THREE.Vector3(0,2,0), elev: 0.25 });

  const N = Math.min(app.swarm.count, 60);
  const dots = [];
  const cores = [];
  for (let i = 0; i < N; i++) {
    const a = (i / N) * Math.PI * 2;
    const x = Math.cos(a) * 6, y = 2, z = Math.sin(a) * 6;
    const m = new THREE.SpriteMaterial({ map: glowTexture, color: 0xff8c1a, transparent: true, blending: THREE.AdditiveBlending, depthWrite: false });
    const s = new THREE.Sprite(m); s.position.set(x, y, z); s.scale.set(0.8, 0.8, 1);
    scene.add(s);
    const core = new THREE.Mesh(new THREE.SphereGeometry(0.1, 8, 6), new THREE.MeshBasicMaterial({ color: 0xff8c1a }));
    core.position.set(x, y, z); scene.add(core);
    dots.push({ sprite: s, core, idx: i });
  }

  document.querySelectorAll('[data-light]').forEach(b => {
    b.addEventListener('click', () => { app.lt.mode = b.dataset.light; document.getElementById('lt-info').textContent = b.dataset.light; });
  });
  document.querySelectorAll('[data-lt-slider]').forEach(row => bindSlider(row, 'lt-slider', (name, v) => { app.lt[name] = v; }));
  document.getElementById('lt-color').addEventListener('input', (e) => { app.lt.color = e.target.value; });

  function resize() {
    const w = canvas.parentElement.clientWidth, h = canvas.parentElement.clientHeight;
    renderer.setSize(w, h, false);
    camera.aspect = w / h; camera.updateProjectionMatrix();
  }
  resize();
  const onResize = () => resize();
  window.addEventListener('resize', onResize);

  let raf = 0;
  function loop() {
    const t = performance.now() * 0.001;
    const intensity = app.lt.intensity / 100;
    dots.forEach(d => {
      let c;
      const speed = app.lt.speed;
      if (app.lt.mode === 'solid') c = new THREE.Color(app.lt.color);
      else if (app.lt.mode === 'gradient') c = new THREE.Color(app.lt.color).multiplyScalar(0.4 + 0.6 * Math.abs(Math.sin((d.idx / N) * Math.PI + t * speed * 0.01)));
      else if (app.lt.mode === 'pulse') {
        const p = 0.4 + 0.6 * Math.max(0, Math.sin(t * speed * 0.05));
        c = new THREE.Color(app.lt.color).multiplyScalar(p);
      } else if (app.lt.mode === 'rainbow') c = new THREE.Color().setHSL((d.idx / N + t * speed * 0.001) % 1, 1.0, 0.6);
      else if (app.lt.mode === 'sparkle') c = (Math.random() < 0.04) ? new THREE.Color(0xffffff) : new THREE.Color(app.lt.color).multiplyScalar(0.15);
      else if (app.lt.mode === 'chase') {
        const head = (t * speed * 0.05) % N;
        const dist = Math.abs(d.idx - head);
        const closest = Math.min(dist, N - dist);
        const v = Math.max(0, 1 - closest / 4);
        c = new THREE.Color(app.lt.color).multiplyScalar(v);
      } else c = new THREE.Color(app.lt.color);
      d.sprite.material.color.copy(c); d.sprite.material.opacity = intensity;
      d.core.material.color.copy(c);
    });
    renderer.render(scene, camera);
    raf = requestAnimationFrame(loop);
  }
  raf = requestAnimationFrame(loop);

  sceneRegistry.lighting = { dispose: () => { cancelAnimationFrame(raf); window.removeEventListener('resize', onResize); orbit.dispose(); renderer.dispose(); } };
}

