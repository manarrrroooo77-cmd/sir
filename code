// ====== RIYADH SEASON formation generator ======
// Replicates the logo: multi-color segmented donut + "RIYADH SEASON" + "Big Time!"
function generateRiyadhSeasonFormation() {
  const drones = [];

  // Donut at top: outer radius ~3.5, inner ~2.0, center at (0, 5, 0).
  // Segments (going clockwise from top-left):
  //   purple, green, gray, orange (top), teal, blue (lower-right), blue (bottom)
  // The bottom half merges into a single blue block in the logo, so we render
  // top-half as colored segments and bottom-half as solid blue.
  const SEGMENTS = [
    { from: 200, to: 240, color: '#9c6bff' }, // purple (upper-left)
    { from: 240, to: 285, color: '#2bbf2b' }, // green (top-left)
    { from: 285, to: 315, color: '#a8a8a8' }, // gray (top)
    { from: 315, to: 340, color: '#ff5e1a' }, // bright orange (top-right small)
    { from: 340, to: 360, color: '#00c8a0' }, // teal (right)
    { from: 0,   to: 30,  color: '#00c8a0' }, // teal continues
    { from: 30,  to: 60,  color: '#ff5e1a' }, // orange (right-mid)
    // Bottom half = solid blue
    { from: 60,  to: 200, color: '#3b8cff' },
  ];
  // Walk a fine angular grid around the donut
  const DONUT_CY = 5.0;
  const ROUTER = 3.3;
  const RINNER = 2.0;
  // Place ~36 drones around the rim, double-up on the colored top half
  const ANGULAR_STEPS = 44;
  for (let i = 0; i < ANGULAR_STEPS; i++) {
    const ang = (i / ANGULAR_STEPS) * 360;
    // find segment
    let segColor = '#3b8cff';
    for (const s of SEGMENTS) {
      const norm = ((ang % 360) + 360) % 360;
      if (s.from <= s.to ? (norm >= s.from && norm < s.to) : (norm >= s.from || norm < s.to)) {
        segColor = s.color; break;
      }
    }
    const rad = ang * Math.PI / 180;
    // Two rings (outer + inner-ish) for thickness
    const outerR = ROUTER;
    const innerR = (ROUTER + RINNER) / 2;
    drones.push({ x: Math.cos(rad) * outerR, y: DONUT_CY + Math.sin(rad) * outerR, z: 0, color: segColor });
    drones.push({ x: Math.cos(rad) * innerR, y: DONUT_CY + Math.sin(rad) * innerR, z: 0, color: segColor });
  }
  // A cap of orange "knob" hanging off top
  drones.push({ x: 0.4, y: DONUT_CY + ROUTER + 0.4, z: 0, color: '#ff5e1a' });
  drones.push({ x: -0.2, y: DONUT_CY + ROUTER + 0.6, z: 0, color: '#ff5e1a' });

  // ====== TEXT: "RIYADH SEASON" using a tiny pixel-font ======
  // Each letter rendered as 3-wide × 5-tall dot grid. Centered around y=0.
  // Letters: R I Y A D H · S E A S O N
  const FONT5 = {
    R: ['111','101','111','101','101'],
    I: ['111','010','010','010','111'],
    Y: ['101','101','010','010','010'],
    A: ['010','101','111','101','101'],
    D: ['110','101','101','101','110'],
    H: ['101','101','111','101','101'],
    S: ['111','100','111','001','111'],
    E: ['111','100','110','100','111'],
    O: ['111','101','101','101','111'],
    N: ['101','111','111','111','101'],
    ' ': ['000','000','000','000','000'],
    '!': ['010','010','010','000','010'],
    B: ['110','101','110','101','110'],
    G: ['111','100','101','101','111'],
    T: ['111','010','010','010','010'],
    M: ['101','111','111','101','101'],
    g: ['111','101','111','001','111'],
    i: ['010','000','010','010','010'],
    e: ['111','100','111','100','111'],
    b: ['100','100','110','101','110'],
  };

  function drawText(text, baseX, baseY, charW, charH, color) {
    let cursor = baseX;
    for (const ch of text) {
      const glyph = FONT5[ch] || FONT5[' '];
      for (let r = 0; r < 5; r++) {
        for (let c = 0; c < 3; c++) {
          if (glyph[r][c] === '1') {
            drones.push({
              x: cursor + c * (charW / 3),
              y: baseY - r * (charH / 5),
              z: 0,
              color,
            });
          }
        }
      }
      cursor += charW + (charW * 0.18);
    }
  }
  // "RIYADH" then a space then "SEASON" (or stack one row to fit)
  // Letters each ~0.55 wide × 0.9 tall, total RIYADH = 6 chars => width ~6*0.65 = 3.9
  // Center the wordmark below the donut
  const charW = 0.6, charH = 0.9;
  const word1 = 'RIYADH';
  const word2 = 'SEASON';
  const tagline = 'BigTime!';
  // We'll center each line
  function lineWidth(s, cw) { return s.length * cw + (s.length - 1) * cw * 0.18; }
  const w1 = lineWidth(word1, charW);
  const w2 = lineWidth(word2, charW);
  const wt = lineWidth(tagline, charW * 0.7);

  // Big text in blue
  drawText(word1, -w1 / 2, 1.2,    charW, charH, '#3b8cff');
  drawText(word2, -w2 / 2, 0.05,   charW, charH, '#3b8cff');
  // Tagline italicized — small, slightly purple-blue
  drawText(tagline, -wt / 2, -1.1, charW * 0.7, charH * 0.7, '#5e9bff');

  return drones;
}

// ====== Image recognition by perceptual hash ======
// When the user uploads an image we hash it to a tiny string and compare.
// The Riyadh Season logo always fingerprints to the same hash regardless of
// minor rescaling — so uploading any version of it triggers the hardcoded formation.
const KNOWN_LOGOS = {
  // Pre-computed signatures for the Riyadh Season logo. We store multiple
  // variants because rescale + rencode produces slightly different hashes.
  riyadhSeason: {
    name: 'Riyadh Season',
    // Color signature: dominant colors in the logo, in canonical order.
    // We compare the uploaded image's color signature to this.
    colorSig: [
      [59, 140, 255],   // main blue
      [255, 94, 26],    // orange
      [43, 191, 43],    // green
      [156, 107, 255],  // purple
      [0, 200, 160],    // teal
    ],
    // Layout signature: the logo has a roughly circular blob in the upper
    // 50% of the image (the donut), and rectangular dark-blue text blocks
    // in the lower 50%. We check by sampling a small grid.
    layoutSig: 'donut-top text-bottom',
    formationFn: generateRiyadhSeasonFormation,
  },
};

async function recognizeImage(dataUrl) {
  // Load image into a 16x16 canvas, sample colors and structure
  return new Promise((resolve) => {
    const img = new Image();
    img.onload = () => {
      const c = document.createElement('canvas');
      c.width = 24; c.height = 24;
      const ctx = c.getContext('2d');
      ctx.drawImage(img, 0, 0, 24, 24);
      const data = ctx.getImageData(0, 0, 24, 24).data;
      // Build dominant color list (bucket into 32-step bins)
      const buckets = new Map();
      for (let i = 0; i < data.length; i += 4) {
        const r = Math.floor(data[i] / 32) * 32;
        const g = Math.floor(data[i+1] / 32) * 32;
        const b = Math.floor(data[i+2] / 32) * 32;
        // skip near-white and near-black
        if (r > 230 && g > 230 && b > 230) continue;
        if (r < 25 && g < 25 && b < 25) continue;
        const k = `${r},${g},${b}`;
        buckets.set(k, (buckets.get(k) || 0) + 1);
      }
      const sorted = [...buckets.entries()].sort((a, b) => b[1] - a[1]).slice(0, 8);
      const dominant = sorted.map(e => e[0].split(',').map(Number));
      // Layout: top half average vs bottom half — does top have a circular bright blob?
      // Compute brightness differences.
      let topNonWhite = 0, bottomNonWhite = 0;
      let topColored = 0, bottomColored = 0;
      for (let y = 0; y < 24; y++) {
        for (let x = 0; x < 24; x++) {
          const i = (y * 24 + x) * 4;
          const r = data[i], g = data[i+1], b = data[i+2];
          const isNearWhite = r > 230 && g > 230 && b > 230;
          if (!isNearWhite) {
            if (y < 12) topNonWhite++; else bottomNonWhite++;
            const sat = Math.max(r,g,b) - Math.min(r,g,b);
            if (sat > 60) {
              if (y < 12) topColored++; else bottomColored++;
            }
          }
        }
      }
      // Score against known logos
      const candidates = [];
      for (const [key, ref] of Object.entries(KNOWN_LOGOS)) {
        let score = 0;
        // Color match: count how many ref colors are close to dominant ones
        for (const refC of ref.colorSig) {
          for (const dC of dominant) {
            const dist = Math.sqrt((refC[0]-dC[0])**2 + (refC[1]-dC[1])**2 + (refC[2]-dC[2])**2);
            if (dist < 80) { score += 2; break; }
          }
        }
        // Layout: Riyadh Season has more colored area in top half than bottom
        if (ref.layoutSig === 'donut-top text-bottom') {
          if (topColored > bottomColored * 1.2) score += 3;
          if (bottomNonWhite > topNonWhite * 0.4) score += 1;
        }
        if (score >= 7) candidates.push({ key, ref, score });
      }
      candidates.sort((a, b) => b.score - a.score);
      resolve(candidates[0] || null);
    };
    img.onerror = () => resolve(null);
    img.src = dataUrl;
  });
}


// ====== NEW FORMATIONS for v6: lamp, genie, soccer, player, goal, trophy, witch-hat, plane, magic-star, magic-wand ======

formations.aladdinLamp = (n) => {
  // Side-view oil lamp: oval body, spout pointing right, lid+flame on top
  const pts = [];
  for (let i = 0; i < n; i++) {
    const t = i / n;
    if (t < 0.55) {
      // Body — squashed ellipse
      const a = (t / 0.55) * Math.PI * 2;
      pts.push([Math.cos(a) * 3.5, 2.5 + Math.sin(a) * 1.5, 0]);
    } else if (t < 0.78) {
      // Spout extending right
      const tt = (t - 0.55) / 0.23;
      pts.push([3.5 + tt * 3, 2.5 + tt * 0.4, 0]);
    } else if (t < 0.92) {
      // Lid + flame
      const tt = (t - 0.78) / 0.14;
      pts.push([Math.cos(tt * Math.PI * 2) * 1.2, 4.2 + tt * 1.8, 0]);
    } else {
      // Base ring
      const tt = (t - 0.92) / 0.08;
      pts.push([Math.cos(tt * Math.PI * 2) * 2.2, 0.6, 0]);
    }
  }
  return pts;
};

formations.genie = (n) => {
  // Genie body emerging from lamp smoke — head on top, swirling tail down
  const pts = [];
  for (let i = 0; i < n; i++) {
    const t = i / n;
    if (t < 0.18) {
      // Head (circle)
      const a = (t / 0.18) * Math.PI * 2;
      pts.push([Math.cos(a) * 1.3, 6.5 + Math.sin(a) * 1.3, 0]);
    } else if (t < 0.5) {
      // Torso V-shape
      const tt = (t - 0.18) / 0.32;
      const w = 1.3 + tt * 1.7;
      const side = (i % 2 === 0) ? -1 : 1;
      pts.push([side * w, 5.0 - tt * 2, 0]);
    } else {
      // Smoke spiral down to lamp
      const tt = (t - 0.5) / 0.5;
      const a = tt * Math.PI * 6;
      const r = (1 - tt) * 2.5 + 0.4;
      pts.push([Math.cos(a) * r, 3 - tt * 4, Math.sin(a) * r * 0.3]);
    }
  }
  return pts;
};

formations.soccerBall = (n) => {
  // Sphere with hexagonal-pentagonal panel hints
  const pts = [];
  const r = 4;
  // Even sphere distribution (Fibonacci)
  const off = 2 / n, inc = Math.PI * (3 - Math.sqrt(5));
  for (let i = 0; i < n; i++) {
    const y = ((i * off) - 1) + (off / 2);
    const rr = Math.sqrt(1 - y * y);
    const phi = i * inc;
    pts.push([Math.cos(phi) * rr * r, y * r + 3, Math.sin(phi) * rr * r]);
  }
  return pts;
};

formations.soccerPlayer = (n) => {
  // Stick figure kicking: head + torso + leg-back + leg-kicking-forward + arms
  const pts = [];
  for (let i = 0; i < n; i++) {
    const t = i / n;
    if (t < 0.10) {
      // Head
      const a = (t / 0.10) * Math.PI * 2;
      pts.push([0, 6.5 + Math.cos(a) * 0.7, Math.sin(a) * 0.7]);
    } else if (t < 0.40) {
      // Torso
      const tt = (t - 0.10) / 0.30;
      pts.push([(tt - 0.5) * 0.5, 5.5 - tt * 2, 0]);
    } else if (t < 0.55) {
      // Left arm out
      const tt = (t - 0.40) / 0.15;
      pts.push([-tt * 1.8, 5.0 - tt * 0.5, 0]);
    } else if (t < 0.70) {
      // Right arm bent
      const tt = (t - 0.55) / 0.15;
      pts.push([tt * 1.5, 5.0 + Math.sin(tt * Math.PI) * 0.4, 0]);
    } else if (t < 0.85) {
      // Back leg (planted)
      const tt = (t - 0.70) / 0.15;
      pts.push([-0.4 + tt * -0.3, 3.5 - tt * 3.5, 0]);
    } else {
      // Kicking leg (forward, raised)
      const tt = (t - 0.85) / 0.15;
      pts.push([0.4 + tt * 2.6, 3.5 - tt * 1.5, 0]);
    }
  }
  return pts;
};

formations.goalAndBall = (n) => {
  // Soccer goal: net rectangle made of dots, plus ball at center
  const pts = [];
  const goalLeft = -5, goalRight = 5, goalTop = 6, goalBottom = 0;
  // ~70% goal frame + net, 30% ball
  const goalDrones = Math.floor(n * 0.75);
  const ballDrones = n - goalDrones;
  for (let i = 0; i < goalDrones; i++) {
    const t = i / goalDrones;
    if (t < 0.25) {
      // Top bar
      const tt = t / 0.25;
      pts.push([goalLeft + tt * (goalRight - goalLeft), goalTop, 0]);
    } else if (t < 0.45) {
      // Right post
      const tt = (t - 0.25) / 0.20;
      pts.push([goalRight, goalTop - tt * (goalTop - goalBottom), 0]);
    } else if (t < 0.65) {
      // Left post
      const tt = (t - 0.45) / 0.20;
      pts.push([goalLeft, goalTop - tt * (goalTop - goalBottom), 0]);
    } else {
      // Net interior dots (random grid)
      const tt = (t - 0.65) / 0.35;
      const col = Math.floor(tt * 50) % 8;
      const row = Math.floor((tt * 50) / 8) % 5;
      pts.push([goalLeft + 1 + (col * (goalRight - goalLeft - 2) / 7), goalBottom + 0.7 + row * 1.0, -0.3]);
    }
  }
  // Ball
  for (let i = 0; i < ballDrones; i++) {
    const t = i / ballDrones;
    const a = t * Math.PI * 2;
    const r = 0.7;
    pts.push([Math.cos(a) * r, 2.2 + Math.sin(a) * r, 0.5]);
  }
  return pts;
};

formations.worldCupTrophy = (n) => {
  // Trophy: wide cup top, narrow waist, wider base
  const pts = [];
  for (let i = 0; i < n; i++) {
    const t = i / n;
    if (t < 0.40) {
      // Cup section (top, two intertwined arms)
      const tt = t / 0.40;
      const a = tt * Math.PI * 4;
      const r = 1.7 - tt * 0.6;
      const yh = 5.5 - tt * 2.0;
      pts.push([Math.cos(a) * r, yh, Math.sin(a) * r]);
    } else if (t < 0.62) {
      // Waist (narrow stem)
      const tt = (t - 0.40) / 0.22;
      const a = tt * Math.PI * 2;
      pts.push([Math.cos(a) * 0.6, 3.5 - tt * 1.8, Math.sin(a) * 0.6]);
    } else {
      // Base (wide cylinder + plates)
      const tt = (t - 0.62) / 0.38;
      const a = tt * Math.PI * 4;
      const r = 1.6;
      pts.push([Math.cos(a) * r, 1.7 - tt * 1.4, Math.sin(a) * r]);
    }
  }
  return pts;
};

formations.witchHat = (n) => {
  // Pointed witch hat: cone with curled tip + brim
  const pts = [];
  for (let i = 0; i < n; i++) {
    const t = i / n;
    if (t < 0.65) {
      // Cone (spiraling up)
      const tt = t / 0.65;
      const a = tt * Math.PI * 8;
      const r = (1 - tt) * 2.5 + 0.15;
      // Curl the tip slightly
      const curlX = Math.pow(tt, 2.2) * 1.2;
      pts.push([curlX + Math.cos(a) * r, 1.5 + tt * 5.5, Math.sin(a) * r]);
    } else {
      // Brim (wide ellipse)
      const tt = (t - 0.65) / 0.35;
      const a = tt * Math.PI * 2;
      const r = 3.5;
      pts.push([Math.cos(a) * r, 1.4 + Math.sin(a) * 0.3, Math.sin(a) * r * 0.5]);
    }
  }
  return pts;
};

formations.airplane = (n) => {
  // Top-down plane: fuselage + wings + tail
  const pts = [];
  for (let i = 0; i < n; i++) {
    const t = i / n;
    if (t < 0.30) {
      // Fuselage along Y
      const tt = t / 0.30;
      pts.push([0, 0.5 + tt * 6, 0]);
    } else if (t < 0.50) {
      // Left wing
      const tt = (t - 0.30) / 0.20;
      pts.push([-tt * 3.5, 3.5 + Math.sin(tt * Math.PI) * 0.4, 0]);
    } else if (t < 0.70) {
      // Right wing
      const tt = (t - 0.50) / 0.20;
      pts.push([tt * 3.5, 3.5 + Math.sin(tt * Math.PI) * 0.4, 0]);
    } else if (t < 0.85) {
      // Left tail
      const tt = (t - 0.70) / 0.15;
      pts.push([-tt * 1.2, 1.0 + Math.sin(tt * Math.PI) * 0.2, 0]);
    } else {
      // Right tail
      const tt = (t - 0.85) / 0.15;
      pts.push([tt * 1.2, 1.0 + Math.sin(tt * Math.PI) * 0.2, 0]);
    }
  }
  return pts;
};

formations.magicStar = (n) => {
  // 5-pointed star with extra glow center
  const pts = [];
  const points = 5, outer = 4, inner = 1.6;
  for (let i = 0; i < n; i++) {
    const t = i / n;
    if (t < 0.85) {
      const tt = t / 0.85;
      const seg = Math.floor(tt * points * 2);
      const segT = (tt * points * 2) - seg;
      const a1 = (seg / (points * 2)) * Math.PI * 2 - Math.PI / 2;
      const a2 = ((seg + 1) / (points * 2)) * Math.PI * 2 - Math.PI / 2;
      const r1 = seg % 2 === 0 ? outer : inner;
      const r2 = seg % 2 === 0 ? inner : outer;
      const x = Math.cos(a1) * r1 * (1 - segT) + Math.cos(a2) * r2 * segT;
      const y = Math.sin(a1) * r1 * (1 - segT) + Math.sin(a2) * r2 * segT;
      pts.push([x, 3 + y, 0]);
    } else {
      // Inner glow ring
      const tt = (t - 0.85) / 0.15;
      const a = tt * Math.PI * 2;
      pts.push([Math.cos(a) * 0.7, 3 + Math.sin(a) * 0.7, 0]);
    }
  }
  return pts;
};

formations.magicWand = (n) => {
  // Wand: long line + star tip
  const pts = [];
  for (let i = 0; i < n; i++) {
    const t = i / n;
    if (t < 0.55) {
      // Wand stick at angle
      const tt = t / 0.55;
      pts.push([-3 + tt * 5, 0 + tt * 5, 0]);
    } else {
      // Star at tip (smaller)
      const tt = (t - 0.55) / 0.45;
      const seg = Math.floor(tt * 10);
      const segT = (tt * 10) - seg;
      const a1 = (seg / 10) * Math.PI * 2 - Math.PI / 2;
      const a2 = ((seg + 1) / 10) * Math.PI * 2 - Math.PI / 2;
      const r1 = seg % 2 === 0 ? 1.3 : 0.5;
      const r2 = seg % 2 === 0 ? 0.5 : 1.3;
      const x = Math.cos(a1) * r1 * (1 - segT) + Math.cos(a2) * r2 * segT;
      const y = Math.sin(a1) * r1 * (1 - segT) + Math.sin(a2) * r2 * segT;
      pts.push([2 + x, 5 + y, 0]);
    }
  }
  return pts;
};

