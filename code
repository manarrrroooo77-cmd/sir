const formations = {
  circle: (n) => { const pts=[],r=6; for(let i=0;i<n;i++){const a=(i/n)*Math.PI*2;pts.push([Math.cos(a)*r,2,Math.sin(a)*r]);} return pts; },
  ring:   (n) => formations.circle(n).map(([x,y,z]) => [x, y+1, z]),
  sphere: (n) => { const pts=[],r=5,off=2/n,inc=Math.PI*(3-Math.sqrt(5)); for(let i=0;i<n;i++){const y=((i*off)-1)+(off/2);const rr=Math.sqrt(1-y*y);const phi=i*inc;pts.push([Math.cos(phi)*rr*r,y*r+2,Math.sin(phi)*rr*r]);} return pts; },
  grid:   (n) => { const pts=[],side=Math.ceil(Math.sqrt(n)),sp=1.2; let i=0; for(let x=0;x<side&&i<n;x++)for(let z=0;z<side&&i<n;z++){pts.push([(x-side/2)*sp,2,(z-side/2)*sp]);i++;} return pts; },
  helix:  (n) => { const pts=[],r=4,h=10,turns=3; for(let i=0;i<n;i++){const t=i/n;const a=t*Math.PI*2*turns;pts.push([Math.cos(a)*r,t*h,Math.sin(a)*r]);} return pts; },
  star:   (n) => { const pts=[],points=5,outer=6,inner=2.5; for(let i=0;i<n;i++){const t=i/n;const seg=Math.floor(t*points*2);const segT=(t*points*2)-seg;const a1=(seg/(points*2))*Math.PI*2-Math.PI/2;const a2=((seg+1)/(points*2))*Math.PI*2-Math.PI/2;const r1=seg%2===0?outer:inner;const r2=seg%2===0?inner:outer;const x=(Math.cos(a1)*r1)*(1-segT)+(Math.cos(a2)*r2)*segT;const z=(Math.sin(a1)*r1)*(1-segT)+(Math.sin(a2)*r2)*segT;pts.push([x,2,z]);} return pts; },
  heart:  (n) => { const pts=[],s=0.4; for(let i=0;i<n;i++){const t=(i/n)*Math.PI*2;const x=16*Math.sin(t)**3;const y=13*Math.cos(t)-5*Math.cos(2*t)-2*Math.cos(3*t)-Math.cos(4*t);pts.push([x*s,y*s+3,0]);} return pts; },
  wave:   (n) => { const pts=[]; for(let i=0;i<n;i++){const t=i/(n-1);const x=(t-0.5)*14;const y=2+Math.sin(t*Math.PI*4)*1.5;pts.push([x,y,0]);} return pts; },
};
const FORMATION_PALETTES = {
  circle: ['#ff8c1a','#ffaa55','#ffd54f','#fff'],
  sphere: ['#4dd0e1','#80deea','#fff'],
  grid:   ['#b388ff','#7c4dff','#fff'],
  helix:  ['#66bb6a','#aed581','#fff'],
  star:   ['#ffd54f','#ffeb3b','#fff'],
  heart:  ['#ff80ab','#ef5350','#ff8c1a'],
  wave:   ['#4dd0e1','#26c6da','#80deea'],
  ring:   ['#ff8c1a','#ffd54f','#fff'],
  ai:     ['#ff8c1a','#4dd0e1','#fff'],
};
function pickPalette(palette, t) {
  const n = palette.length; const idx = t * (n - 1); const i = Math.floor(idx); const f = idx - i;
  if (i >= n - 1) return palette[n - 1];
  const a = new THREE.Color(palette[i]); const b = new THREE.Color(palette[i + 1]);
  return '#' + a.lerp(b, f).getHexString();
}
function buildSwarmFromFormation(name, n, customDrones) {
  app.swarm.count = n;
  app.swarm.formation = name;
  if (customDrones) {
    app.swarm.drones = customDrones.slice(0, n).map((d, i) => ({ id: i+1, x: d.x, y: d.y, z: d.z, color: d.color }));
  } else {
    const pts = (formations[name] || formations.circle)(n);
    const palette = FORMATION_PALETTES[name] || ['#ff8c1a'];
    app.swarm.drones = pts.map((p, i) => ({ id: i+1, x: p[0], y: p[1], z: p[2], color: pickPalette(palette, i / Math.max(1, n-1)) }));
  }
  document.getElementById('globalDroneCount').textContent = n;
}
