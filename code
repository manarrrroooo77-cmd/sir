// Returns an SVG string of a stylized cartoon face — Memoji-inspired.
// Customisable via seed (skin tone, hair color, eye color, hair style, accessory)
function makeMemoji(seed) {
  const SKIN = ['#fdcfa3', '#e8b48f', '#c98e6e', '#8b5a3c', '#f5d8b8', '#d4a274'];
  const HAIR = ['#2a1810', '#3d2817', '#7a4a2a', '#c97f3d', '#e8c47a', '#1a1a1a', '#4a2c2a', '#6b3410', '#bd5d3a'];
  const EYE = ['#3a2a1a', '#1a3a5a', '#2a4a2a', '#4a3a2a'];
  const ACCESS = ['none', 'glasses', 'earrings', 'none', 'none'];
  const HAIRSTYLE = ['short', 'curly', 'long', 'bun', 'cap', 'bald'];

  // Simple deterministic hash from seed string
  let h = 0;
  for (let i = 0; i < seed.length; i++) h = (h * 31 + seed.charCodeAt(i)) | 0;
  h = Math.abs(h);
  const pick = (arr, n) => arr[((h >> n) % arr.length + arr.length) % arr.length];

  const skin = pick(SKIN, 0);
  const hair = pick(HAIR, 3);
  const eye = pick(EYE, 6);
  const access = pick(ACCESS, 9);
  const style = pick(HAIRSTYLE, 12);

  // Tones for shading
  const skinDark = shade(skin, -18);
  const skinLight = shade(skin, 14);
  const hairDark = shade(hair, -25);
  const id = 'm' + (h % 1000000);

  // Hair styles
  let hairBack = '', hairFront = '';
  if (style === 'short') {
    hairBack = `<ellipse cx="50" cy="38" rx="32" ry="26" fill="${hair}"/>`;
    hairFront = `<path d="M22 38 Q24 22 50 18 Q76 22 78 38 Q70 30 50 28 Q30 30 22 38 Z" fill="${hairDark}"/>`;
  } else if (style === 'curly') {
    hairBack = `<g fill="${hair}">
      <circle cx="32" cy="32" r="11"/><circle cx="42" cy="22" r="11"/><circle cx="55" cy="20" r="12"/>
      <circle cx="68" cy="26" r="11"/><circle cx="74" cy="38" r="10"/><circle cx="22" cy="44" r="9"/>
    </g>`;
    hairFront = '';
  } else if (style === 'long') {
    hairBack = `<path d="M16 50 Q14 30 32 18 Q50 12 70 20 Q86 30 84 56 Q84 70 78 78 Q72 60 70 50 L70 30 L30 30 L30 50 Q28 60 22 78 Q16 70 16 50 Z" fill="${hair}"/>`;
    hairFront = `<path d="M22 36 Q26 22 50 20 Q74 22 78 36 Q70 32 50 30 Q30 32 22 36 Z" fill="${hairDark}"/>`;
  } else if (style === 'bun') {
    hairBack = `<ellipse cx="50" cy="38" rx="30" ry="24" fill="${hair}"/>
      <ellipse cx="50" cy="14" rx="13" ry="10" fill="${hair}"/>
      <ellipse cx="50" cy="13" rx="8" ry="6" fill="${hairDark}" opacity=".5"/>`;
    hairFront = `<path d="M24 36 Q28 24 50 22 Q72 24 76 36 Q66 32 50 32 Q34 32 24 36 Z" fill="${hairDark}"/>`;
  } else if (style === 'cap') {
    hairBack = `<ellipse cx="50" cy="40" rx="30" ry="20" fill="${hair}"/>
      <path d="M22 32 Q24 14 50 12 Q76 14 78 32 Q78 36 76 38 L24 38 Q22 36 22 32 Z" fill="${hairDark}"/>
      <ellipse cx="50" cy="38" rx="32" ry="4" fill="${shade(hairDark, -15)}"/>`;
    hairFront = '';
  } else { /* bald */
    hairBack = '';
    hairFront = '';
  }

  let accessory = '';
  if (access === 'glasses') {
    accessory = `<g fill="none" stroke="#1a1a1a" stroke-width="1.5">
      <circle cx="38" cy="48" r="7" fill="rgba(180,210,230,0.3)"/>
      <circle cx="62" cy="48" r="7" fill="rgba(180,210,230,0.3)"/>
      <line x1="45" y1="48" x2="55" y2="48"/>
      <line x1="31" y1="48" x2="26" y2="46"/>
      <line x1="69" y1="48" x2="74" y2="46"/>
    </g>`;
  } else if (access === 'earrings') {
    accessory = `<g fill="#ffd54f"><circle cx="20" cy="55" r="2"/><circle cx="80" cy="55" r="2"/></g>`;
  }

  // Eye style — slight smile in upper lid
  const eyeY = 48;
  const cheekColor = shade(skin, -8);

  // Smile
  const smile = `<path d="M40 64 Q50 72 60 64" stroke="${shade(skin, -35)}" stroke-width="2" fill="none" stroke-linecap="round"/>`;

  return `<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <radialGradient id="${id}-face" cx="50%" cy="40%" r="65%">
        <stop offset="0%" stop-color="${skinLight}"/>
        <stop offset="65%" stop-color="${skin}"/>
        <stop offset="100%" stop-color="${skinDark}"/>
      </radialGradient>
      <radialGradient id="${id}-bg" cx="50%" cy="50%" r="60%">
        <stop offset="0%" stop-color="${shade(skin, 25)}" stop-opacity=".3"/>
        <stop offset="100%" stop-color="${skin}" stop-opacity="0"/>
      </radialGradient>
    </defs>
    <circle cx="50" cy="50" r="50" fill="url(#${id}-bg)"/>
    ${hairBack}
    <!-- Face/head -->
    <ellipse cx="50" cy="54" rx="26" ry="30" fill="url(#${id}-face)"/>
    <!-- Cheeks -->
    <ellipse cx="32" cy="60" rx="5" ry="3" fill="${cheekColor}" opacity=".5"/>
    <ellipse cx="68" cy="60" rx="5" ry="3" fill="${cheekColor}" opacity=".5"/>
    <!-- Ears -->
    <ellipse cx="22" cy="55" rx="3" ry="5" fill="${skinDark}"/>
    <ellipse cx="78" cy="55" rx="3" ry="5" fill="${skinDark}"/>
    ${hairFront}
    <!-- Eyes -->
    <g>
      <ellipse cx="38" cy="${eyeY}" rx="3.5" ry="4" fill="white"/>
      <ellipse cx="62" cy="${eyeY}" rx="3.5" ry="4" fill="white"/>
      <circle cx="38" cy="${eyeY+0.5}" r="2.2" fill="${eye}"/>
      <circle cx="62" cy="${eyeY+0.5}" r="2.2" fill="${eye}"/>
      <circle cx="38.8" cy="${eyeY-0.5}" r=".8" fill="white"/>
      <circle cx="62.8" cy="${eyeY-0.5}" r=".8" fill="white"/>
      <!-- Eyebrows -->
      <path d="M32 41 Q38 38 44 41" stroke="${hairDark}" stroke-width="1.6" fill="none" stroke-linecap="round"/>
      <path d="M56 41 Q62 38 68 41" stroke="${hairDark}" stroke-width="1.6" fill="none" stroke-linecap="round"/>
    </g>
    <!-- Nose -->
    <path d="M50 50 Q49 56 50 60 Q51 60 52 60" stroke="${shade(skin, -20)}" stroke-width="1.2" fill="none" stroke-linecap="round" opacity=".7"/>
    ${smile}
    ${accessory}
  </svg>`;

  function shade(hex, percent) {
    let r = parseInt(hex.slice(1,3), 16);
    let g = parseInt(hex.slice(3,5), 16);
    let b = parseInt(hex.slice(5,7), 16);
    const f = (percent / 100);
    r = Math.max(0, Math.min(255, Math.round(r + (f > 0 ? 255-r : r) * f)));
    g = Math.max(0, Math.min(255, Math.round(g + (f > 0 ? 255-g : g) * f)));
    b = Math.max(0, Math.min(255, Math.round(b + (f > 0 ? 255-b : b) * f)));
    return '#' + [r,g,b].map(x => x.toString(16).padStart(2,'0')).join('');
  }
}

