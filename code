function initDoors() {
  const grid = document.getElementById('doors-grid');
  const detail = document.getElementById('doors-detail');
  const galleryEl = document.querySelector('.doors-gallery');
  if (!grid || !detail || !galleryEl) return;

  // ====== STATE ======
  let searchQuery = '';
  let activeFilter = 'All';

  // ====== Build a fresh, futuristic gallery (replaces the previous header structure) ======
  // Re-shape the gallery DOM for v6 top-bar
  galleryEl.innerHTML = `
    <div class="doors-topbar">
      <div>
        <h1>Doors of Siraj</h1>
        <div class="topbar-sub">REAL THEATRE · AI VISION · DRONE CONVERSION</div>
      </div>
      <div class="doors-search" id="doorsSearch">
