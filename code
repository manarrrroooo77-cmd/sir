// ====== CUSTOM FORMATIONS for Doors detections ======
// Extend the existing `formations` map with shapes referenced by detections above.
formations.lamp     = (n) => { const pts = []; for (let i = 0; i < n; i++) { const t = i / (n - 1); const a = t * Math.PI * 2; const r = 2.5 + Math.sin(a*2) * 0.5; pts.push([Math.cos(a)*r, 2 + Math.sin(a)*r*0.6, 0]); } return pts; };
formations.carpet   = (n) => { const pts = []; for (let i = 0; i < n; i++) { const t = i / (n - 1); const x = (t - 0.5) * 12; const y = 2 + Math.sin(t * Math.PI * 3) * 0.5; pts.push([x, y, Math.sin(t*Math.PI*2)*0.4]); } return pts; };
formations.palace   = (n) => { const pts = []; for (let i = 0; i < n; i++) { const t = i / (n - 1); const x = (t - 0.5) * 8; const baseY = 0; const dome = Math.exp(-Math.pow((t - 0.5)*4, 2)) * 4; pts.push([x, baseY + dome, 0]); } return pts; };
formations.princess = (n) => { const pts = []; for (let i = 0; i < n; i++) { const t = i / (n - 1); const a = t * Math.PI * 2; const x = Math.sin(t * Math.PI) * 3; const y = t * 6; pts.push([x, y - 1, Math.cos(a)*0.5]); } return pts; };
formations.castle   = (n) => { const pts = []; for (let i = 0; i < n; i++) { const towers = 4; const pt = i / n; const t = Math.floor(pt * towers); const tt = (pt * towers) - t; const tx = (t - towers/2 + 0.5) * 3; const ty = tt * 5; pts.push([tx, ty, 0]); } return pts; };
formations.dragon   = (n) => { const pts = []; for (let i = 0; i < n; i++) { const t = i / (n - 1); const x = (t - 0.5) * 14; const y = 3 + Math.sin(t * Math.PI * 4) * 1.5; const z = Math.cos(t * Math.PI * 3) * 0.8; pts.push([x, y, z]); } return pts; };
formations.wizard   = (n) => { const pts = []; for (let i = 0; i < n; i++) { const t = i / (n - 1); const a = t * Math.PI * 2 * 3; const r = 2 - t * 1.5; pts.push([Math.cos(a)*r, t * 6, Math.sin(a)*r]); } return pts; };
formations.sword    = (n) => { const pts = []; for (let i = 0; i < n; i++) { const t = i / (n - 1); pts.push([0, t * 8 - 1, 0]); } return pts; };
formations.falcon   = (n) => { const pts = []; for (let i = 0; i < n; i++) { const t = i / (n - 1); const x = (t - 0.5) * 12; const y = 4 + Math.abs(Math.sin(t * Math.PI)) * 1.5 - Math.pow(Math.abs(t - 0.5)*2, 2)*1.2; pts.push([x, y, 0]); } return pts; };
formations.palm     = (n) => { const pts = []; for (let i = 0; i < n; i++) { if (i < n * 0.4) { const t = i / (n * 0.4); pts.push([0, t * 5, 0]); } else { const t = (i - n * 0.4) / (n * 0.6); const a = t * Math.PI * 2; const r = (1 - t) * 3; pts.push([Math.cos(a)*r, 5 + t * 2, Math.sin(a)*r]); } } return pts; };
formations.crescent = (n) => { const pts = []; for (let i = 0; i < n; i++) { const t = i / (n - 1); const a = -Math.PI/2 + t * Math.PI * 1.4; const r = 4; pts.push([Math.cos(a)*r, 3 + Math.sin(a)*r, 0]); } return pts; };
formations.dancer   = (n) => { const pts = []; for (let i = 0; i < n; i++) { const t = i / (n - 1); const swing = Math.sin(t * Math.PI * 3) * 1.2; pts.push([swing, t * 6, Math.cos(t * Math.PI * 2) * 0.5]); } return pts; };
formations.genie    = (n) => { const pts = []; for (let i = 0; i < n; i++) { const t = i / (n - 1); const a = t * Math.PI * 2 * 4; const r = (1 - t) * 3 + 0.3; pts.push([Math.cos(a)*r, t * 8, Math.sin(a)*r]); } return pts; };
formations.hat      = (n) => { const pts = []; for (let i = 0; i < n; i++) { const t = i / (n - 1); if (t < 0.3) { const a = (t / 0.3) * Math.PI * 2; pts.push([Math.cos(a)*3, 0.5, Math.sin(a)*3]); } else { const tt = (t - 0.3) / 0.7; const a = tt * Math.PI * 2 * 3; pts.push([Math.cos(a)*1.8, 0.5 + tt * 4, Math.sin(a)*1.8]); } } return pts; };

