    const rect = e.currentTarget.getBoundingClientRect();
    const px = e.clientX - rect.left;
    if (px >= 0) { app.ch.playhead = Math.max(0, Math.min(SHOW_DURATION, px / app.ch.pxPerSec)); updatePlayhead(); }
  });
  document.getElementById('tlTracks').addEventListener('mousedown', (e) => {
    if (e.target.closest('.tl-clip') || e.target.closest('.tl-track-head')) return;
    const rect = e.currentTarget.getBoundingClientRect();
    const px = e.clientX - rect.left - 140;
    if (px >= 0) { app.ch.playhead = Math.max(0, Math.min(SHOW_DURATION, px / app.ch.pxPerSec)); updatePlayhead(); }
  });

  function updatePlayhead() {
    const ph = document.getElementById('tlPlayheadEl');
    if (ph) ph.style.left = (140 + app.ch.playhead * app.ch.pxPerSec) + 'px';
    updateTimecode();
  }
  function updateTimecode() {
    const fmt = (s) => {
      const m = Math.floor(s / 60), sec = Math.floor(s % 60), ms = Math.floor((s * 1000) % 1000);
      return `${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}.${String(ms).padStart(3,'0')}`;
    };
    document.getElementById('tlTime').innerHTML = `${fmt(app.ch.playhead)}<span class="total"> / ${fmt(SHOW_DURATION)}</span>`;
  }
  document.getElementById('delClipBtn').addEventListener('click', () => {
    if (!app.ch.selectedClipId) return;
    app.ch.clips = app.ch.clips.filter(c => c.id !== app.ch.selectedClipId);
    app.ch.selectedClipId = app.ch.clips[0]?.id || null;
    renderTimeline();
  });
  document.getElementById('splitClipBtn').addEventListener('click', () => {
    const c = app.ch.clips.find(x => x.id === app.ch.selectedClipId);
    if (!c) return;
    if (app.ch.playhead <= c.start || app.ch.playhead >= c.start + c.dur) return;
    const right = { ...c, id: app.ch.nextClipId++, start: app.ch.playhead, dur: c.start + c.dur - app.ch.playhead };
    c.dur = app.ch.playhead - c.start;
    app.ch.clips.push(right);
    app.ch.clips.sort((a,b) => a.start - b.start);
    renderTimeline();
  });
  document.getElementById('tlPlay').addEventListener('click', () => {
    app.ch.playing = !app.ch.playing;
    document.getElementById('tlPlay').textContent = app.ch.playing ? '❚❚' : '▶';
  });
  document.getElementById('tlStart').addEventListener('click', () => { app.ch.playhead = 0; updatePlayhead(); });
  document.getElementById('tlEnd').addEventListener('click', () => { app.ch.playhead = SHOW_DURATION - 0.001; updatePlayhead(); });
  document.getElementById('tlZoom').addEventListener('input', (e) => { app.ch.pxPerSec = parseInt(e.target.value); renderTimeline(); });

  const onKey = (e) => {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
    if (e.code === 'Space') { e.preventDefault(); document.getElementById('tlPlay').click(); }
  };
  window.addEventListener('keydown', onKey);

  renderTimeline();

  function resize() {
    const w = canvas.parentElement.clientWidth, h = canvas.parentElement.clientHeight;
    renderer.setSize(w, h, false);
    camera.aspect = w / h; camera.updateProjectionMatrix();
  }
  resize();
  const onResize = () => resize();
  window.addEventListener('resize', onResize);

  let raf = 0; let lastT = performance.now();
  let fpsTimer = 0, fpsCount = 0;
  function loop() {
    const now = performance.now(); const dt = now - lastT; lastT = now;
    if (app.ch.playing) {
      app.ch.playhead += dt / 1000;
      if (app.ch.playhead >= SHOW_DURATION) app.ch.playhead = 0;
      updatePlayhead();
    }
    applyShowAtTime(app.ch.playhead);
    updateDrones(dt);

    fpsTimer += dt; fpsCount++;
    if (fpsTimer > 500) {
      const el = document.getElementById('ch-info-fps');
      if (el) el.textContent = Math.round(1000 / (fpsTimer / fpsCount));
      fpsTimer = 0; fpsCount = 0;
    }
    renderer.render(scene, camera);
    raf = requestAnimationFrame(loop);
  }
  raf = requestAnimationFrame(loop);

  sceneRegistry.choreography = {
    dispose: () => {
      cancelAnimationFrame(raf);
      window.removeEventListener('resize', onResize);
      window.removeEventListener('mousemove', moveH);
      window.removeEventListener('mouseup', upH);
      window.removeEventListener('keydown', onKey);
      orbit.dispose();
      renderer.dispose();
    }
  };
}

// ============== PAGE: SINGLE DRONE EDITOR ==============
function initDroneEdit(droneId) {
  if (!droneId) droneId = 1;
  app.editingDroneId = droneId;
  document.getElementById('de-bc-title').textContent = `Drone #${String(droneId).padStart(3,'0')}`;
  document.getElementById('de-info-id').textContent = '#' + String(droneId).padStart(3,'0');

  const canvas = document.getElementById('de-canvas');
  const renderer = makeRendererForCanvas(canvas, { clearColor: 0x080a10 });
  const scene = new THREE.Scene();
  scene.fog = new THREE.FogExp2(0x080a10, 0.04);
  const camera = new THREE.PerspectiveCamera(40, 1, 0.05, 50);
  scene.add(new THREE.AmbientLight(0x2a2f3a, 0.4));
  const key = new THREE.DirectionalLight(0xfff5e0, 0.7); key.position.set(2, 4, 3); scene.add(key);
  const rim = new THREE.DirectionalLight(0x4dd0e1, 0.5); rim.position.set(-2, 1, -3); scene.add(rim);
  const fill = new THREE.DirectionalLight(0xb388ff, 0.3); fill.position.set(2, -1, -2); scene.add(fill);

  const orbit = attachOrbitControls(canvas, camera, { dist: 3.5, target: new THREE.Vector3(0,0,0), elev: 0.15, minDist: 1.5, maxDist: 10 });

  // Default LEDs from the photo: pink, green, yellow, white
  const leds = app.droneLEDs[droneId] || ['#f5d0e0','#cdfacd','#fff58a','#ffffff'];
  app.droneLEDs[droneId] = leds.slice();

  const drone = makeCagedDrone({ radius: 1, subdiv: 2, tint: '#7e2a8c', leds });
  scene.add(drone);

  // LED controls
  const ledLabels = ['Top ring','Upper ring','Lower ring','Bottom ring'];
  const ledContainer = document.getElementById('de-leds');
  ledContainer.innerHTML = leds.map((c, i) => `
    <div class="led-cell">
      <div class="swatch" style="background:${c}; color:${c};">
        <input type="color" value="${c}" data-ring="${i}">
      </div>
      <div>
        <div class="name">${ledLabels[i]}</div>
        <div class="ring">Ring ${i+1} · ${(i===0||i===3)?'8 LEDs':'12 LEDs'}</div>
      </div>
      <button class="btn sm" data-flash="${i}">Flash</button>
    </div>
  `).join('');
  ledContainer.querySelectorAll('input[type="color"]').forEach(inp => {
    inp.addEventListener('input', (e) => {
      const ring = parseInt(e.target.dataset.ring);
      const hex = e.target.value;
      app.droneLEDs[droneId][ring] = hex;
      drone.userData.ledNodes.forEach(n => {
        if (n.userData.led.ring === ring) {
          const c = new THREE.Color(hex);
          n.material.color.copy(c).multiplyScalar(0.4);
          n.material.emissive.copy(c);
          n.userData.glow.material.color.copy(c);
        }
      });
      e.target.parentElement.style.background = hex;
      e.target.parentElement.style.color = hex;
    });
  });
  ledContainer.querySelectorAll('[data-flash]').forEach(b => {
    b.addEventListener('click', () => {
      const ring = parseInt(b.dataset.flash);
      drone.userData.ledNodes.forEach(n => {
        if (n.userData.led.ring === ring) {
          n.material.emissiveIntensity = 5;
          setTimeout(() => { n.material.emissiveIntensity = 1.2; }, 300);
        }
      });
    });
  });

  let propsRpm = 60, glowAmt = 0.8;
  document.querySelectorAll('[data-de-slider]').forEach(row => bindSlider(row, 'de-slider', (name, v) => {
    if (name === 'props') propsRpm = v;
    if (name === 'glow') {
      glowAmt = v / 100;
      drone.userData.ledNodes.forEach(n => { n.userData.glow.material.opacity = 0.6 * glowAmt; n.material.emissiveIntensity = 0.4 + 1.2 * glowAmt; });
    }
  }));

  function resize() {
    const w = canvas.parentElement.clientWidth, h = canvas.parentElement.clientHeight;
    renderer.setSize(w, h, false);
    camera.aspect = w / h; camera.updateProjectionMatrix();
  }
  resize();
  const onResize = () => resize();
  window.addEventListener('resize', onResize);

  let raf = 0; let lastT = performance.now();
  let propAngle = 0;
  function loop() {
    const now = performance.now(); const dt = now - lastT; lastT = now;
    propAngle += dt * 0.001 * propsRpm;
    drone.rotation.y += dt * 0.0003;
    drone.userData.body.userData.props.rotation.y = propAngle;
    renderer.render(scene, camera);
    raf = requestAnimationFrame(loop);
  }
  raf = requestAnimationFrame(loop);

  sceneRegistry['drone-edit'] = {
    dispose: () => {
      cancelAnimationFrame(raf);
      window.removeEventListener('resize', onResize);
      orbit.dispose();
      renderer.dispose();
    }
  };
}

